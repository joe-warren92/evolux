---
interface Props {
  id: string;
  name: string;
  tagline: string;
  price: string;
  features: string[];
  highlight?: boolean;
  note?: string;
  ctaHref?: string;
  ctaText?: string;
}

const {
  id,
  name,
  tagline,
  price,
  features,
  highlight = false,
  note = "Starting from",
  ctaHref = "/contact",
  ctaText = `Ask about ${name}`
} = Astro.props;

const hasPriceSuffix = note.startsWith("/");
---

<article class:list={["package-card", highlight && "package-card--featured"]} data-package={id}>
  {highlight && <span class="package-card__badge">Most popular</span>}
  <div class="package-card__head">
    <p class="package-card__name">{name}</p>
    <p>{tagline}</p>
    {!hasPriceSuffix && <span class="type-index">{note}</span>}
    <h3><span set:html={price}></span>{hasPriceSuffix && <small>{note}</small>}</h3>
  </div>
  <ul>
    {features.map((feature) => <li>{feature}</li>)}
  </ul>
  <a href={ctaHref}>{ctaText} <span aria-hidden="true">&#8599;</span></a>
</article>
