---
import googleReviewsData from "../data/googleReviews.json";

const currentYear = new Date().getFullYear();

const companyLinks = [
  ["About Evolux Web Design", "/about"],
  ["Evolux web design projects", "/projects"],
  ["Web design services", "/services"],
  ["Web design packages", "/packages"],
  ["Web design insights", "/insights"],
  ["Web design locations", "/locations"],
  ["Get a free website review", "/free-review"],
  ["Contact Evolux Web Design", "/contact"]
];

const legalLinks = [
  ["Privacy Policy", "/privacy-policy"],
  ["Terms & Conditions", "/terms-and-conditions"],
  ["Cookie Policy", "/cookie-policy"]
];

const socialLinks = [
  ["Instagram", "https://www.instagram.com/evoluxwebdesign/"],
  ["Facebook", "https://www.facebook.com/evoluxwebdesign"],
  ["LinkedIn", "https://www.linkedin.com/company/evolux-web-design/"]
];

const googleReviews = googleReviewsData.reviews.filter((review) => review.text);
const googleRating = Number(googleReviewsData.rating || 5).toFixed(1);
const googleReviewCount = googleReviewsData.reviewCount || googleReviews.length;
const googleSourceUrl = googleReviewsData.sourceUrl || "https://www.google.com/search?q=Evolux+Web+Design+reviews";

const getStars = (rating) => "★".repeat(Math.max(1, Math.min(5, Math.round(rating || 5))));
---

<footer id="contact">
  <section class="footer-testimonials">
    <div class="footer-testimonials__inner">
      <div class="footer-testimonials__head">
        <div>
          <div class="section-kicker"><span></span><p class="type-index">What clients say</p></div>
          <h2 class="display-heading"><span>Real Google reviews.</span><br />Clearer proof.</h2>
        </div>
        <div class="footer-testimonials__rating">
          <div class="google-review-mark" aria-label="Google reviews">
            <span class="google-review-mark__g" aria-hidden="true">
              <span>G</span>
            </span>
            <span>Google reviews</span>
          </div>
          <div class="stars" aria-label={`${googleRating} star Google rating`}>{getStars(googleReviewsData.rating)}</div>
          <p>{googleRating} rating{googleReviewCount ? ` from ${googleReviewCount} reviews` : ""}</p>
        </div>
      </div>

      <div class="google-reviews-carousel" data-google-reviews-carousel>
        <div class="google-reviews-carousel__track" tabindex="0" aria-label="Google review carousel">
          {googleReviews.map((review) => (
            <article class="testimonial-card">
              <header>
                <div class="stars" aria-label={`${review.rating} star Google review`}>{getStars(review.rating)}</div>
                <span class="testimonial-card__source">Google</span>
              </header>
              <blockquote>"{review.text}"</blockquote>
              <footer>
                <span>{review.authorInitials}</span>
                <div>
                  <strong>{review.authorName}</strong>
                  <p>{review.company || review.relativeTimeDescription}</p>
                </div>
              </footer>
            </article>
          ))}
        </div>
        <div class="google-reviews-carousel__footer">
          <a href={googleSourceUrl} target="_blank" rel="noreferrer">Read more reviews on Google <span aria-hidden="true">&#8599;</span></a>
          <div class="google-reviews-carousel__controls" aria-label="Review carousel controls">
            <button type="button" data-review-prev aria-label="Previous review">‹</button>
            <button type="button" data-review-next aria-label="Next review">›</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="evolux-footer">
    <div class="evolux-footer__glow"></div>
    <div class="evolux-footer__inner">
      <div class="evolux-footer__grid">
        <div class="evolux-footer__cta">
          <h2><span>Let's build something</span> incredible together.</h2>
          <div class="evolux-footer__actions">
            <a class="button button--accent" href="/contact">Contact Evolux about a web design project <span aria-hidden="true">&#8599;</span></a>
            <a class="button button--outline-light" href="mailto:info@evoluxwebdesign.co.uk">Send an email</a>
          </div>
          <div class="evolux-footer__location">
            <p class="type-index">Based in</p>
            <strong>Sunderland, Tyne &amp; Wear</strong>
            <p>North East England</p>
          </div>
        </div>

        <nav class="evolux-footer__links" aria-label="Footer navigation">
          <div>
            <h3>Social</h3>
            {socialLinks.map(([label, href]) => (
              <a href={href} target="_blank" rel="noreferrer">{label} <span aria-hidden="true">&#8599;</span></a>
            ))}
          </div>
          <div>
            <h3>Contact</h3>
            <a href="mailto:info@evoluxwebdesign.co.uk">info@evoluxwebdesign.co.uk</a>
            <a href="tel:+447854932203">+44 7854 932203</a>
          </div>
          <div>
            <h3>Company</h3>
            {companyLinks.map(([label, href]) => <a href={href}>{label}</a>)}
          </div>
          <div>
            <h3>Legal</h3>
            {legalLinks.map(([label, href]) => <a href={href}>{label}</a>)}
          </div>
        </nav>
      </div>

      <div class="evolux-footer__bottom">
        <p>&copy; {currentYear} Evolux Web Design Ltd. All rights reserved.</p>
        <p>Web Design &amp; Development · Sunderland, UK</p>
      </div>
      <div class="evolux-footer__wordmark">EVOLUX</div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const carousel = document.querySelector("[data-google-reviews-carousel]");
      if (!carousel) return;

      const track = carousel.querySelector(".google-reviews-carousel__track");
      const previous = carousel.querySelector("[data-review-prev]");
      const next = carousel.querySelector("[data-review-next]");
      if (!track || !previous || !next) return;

      const scrollReview = (direction) => {
        const firstCard = track.querySelector(".testimonial-card");
        const distance = firstCard ? firstCard.getBoundingClientRect().width + 24 : track.clientWidth * 0.85;
        track.scrollBy({ left: distance * direction, behavior: "smooth" });
      };

      previous.addEventListener("click", () => scrollReview(-1));
      next.addEventListener("click", () => scrollReview(1));
    })();
  </script>
</footer>
