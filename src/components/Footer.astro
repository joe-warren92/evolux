---
import GoogleReviewsSection from "./GoogleReviewsSection.astro";

interface Props {
  hideReviews?: boolean;
}

const currentYear = new Date().getFullYear();
const { hideReviews = false } = Astro.props;

const primaryLinks = [
  ["Home", "/"],
  ["Projects", "/projects"],
  ["Services", "/services"],
  ["Packages", "/packages"],
  ["About", "/about"]
];

const serviceLinks = [
  ["Web Design", "/services/web-design"],
  ["Website Maintenance", "/services/website-maintenance"],
  ["Conversion Optimisation", "/services/conversion-optimisation"],
  ["Brand Identity", "/services/branding"],
  ["Graphic Design", "/services/graphic-design"],
  ["All web design services", "/services"]
];

const resourceLinks = [
  ["Free Website Review", "/free-review"],
  ["Insights", "/insights"],
  ["Industries", "/industries"],
  ["Locations", "/locations"],
  ["Contact", "/contact"]
];

const industryLinks = [
  ["Accountants", "/industries/accountants"],
  ["Consultants", "/industries/consultants"],
  ["Solicitors", "/industries/solicitors"],
  ["Financial Advisers", "/industries/financial-advisers"],
  ["Recruitment Agencies", "/industries/recruitment"],
  ["Architects", "/industries/architects"],
  ["Engineers", "/industries/engineers"],
  ["Private Clinics", "/industries/private-clinics"],
  ["Training Providers", "/industries/training-providers"],
  ["Trades", "/industries/trades"]
];

const locationLinks = [
  ["Sunderland", "/locations/sunderland"],
  ["Newcastle upon Tyne", "/locations/newcastle-upon-tyne"],
  ["Durham", "/locations/durham"],
  ["Gateshead", "/locations/gateshead"],
  ["Middlesbrough", "/locations/middlesbrough"],
  ["Nationwide", "/locations/nationwide"]
];

const socialLinks = [
  ["Instagram", "https://www.instagram.com/evoluxwebdesign/"],
  ["Facebook", "https://www.facebook.com/evoluxwebdesign"],
  ["LinkedIn", "https://www.linkedin.com/company/evolux-web-design/"]
];
---

<footer id="contact">
  {!hideReviews && <GoogleReviewsSection />}

  <section class="evolux-footer">
    <div class="evolux-footer__glow"></div>
    <div class="evolux-footer__inner">
      <div class="evolux-footer__grid">
        <div class="evolux-footer__cta">
          <h2><span>Make your website</span> easier to trust.</h2>
          <div class="evolux-footer__actions">
            <a class="button button--accent" href="/contact">Contact Evolux <span aria-hidden="true">↗</span></a>
            <a class="button button--outline-light" href="/contact">Send a project enquiry</a>
          </div>
          <div class="evolux-footer__location">
            <p class="type-index">Based in</p>
            <strong>Evolux Web Design</strong>
            <p>Sunderland, Tyne &amp; Wear, UK</p>
            <p><a href="tel:+447854932203">Phone: +44 7854 932203</a></p>
          </div>
        </div>

        <nav class="evolux-footer__links" aria-label="Footer navigation">
          <div class="evolux-footer__contact">
            <h3>Contact</h3>
            <a href="/contact">Contact Evolux</a>
            <a href="tel:+447854932203">+44 7854 932203</a>
            <p>Sunderland, Tyne &amp; Wear, UK</p>
            <div class="evolux-footer__social">
              {socialLinks.map(([label, href]) => (
                <a href={href} target="_blank" rel="noreferrer">{label} <span aria-hidden="true">↗</span></a>
              ))}
            </div>
          </div>
          <div>
            <h3>Main</h3>
            {primaryLinks.map(([label, href]) => <a href={href}>{label}</a>)}
          </div>
          <div>
            <h3>Services</h3>
            {serviceLinks.map(([label, href]) => <a href={href}>{label}</a>)}
          </div>
          <div>
            <h3>Resources</h3>
            {resourceLinks.map(([label, href]) => <a href={href}>{label}</a>)}
          </div>
          <section class="evolux-footer__directory">
            <h3>Industries</h3>
            <div>
              {industryLinks.map(([label, href]) => <a href={href}>{label}</a>)}
            </div>
          </section>
          <section class="evolux-footer__directory">
            <h3>Locations</h3>
            <div>
              {locationLinks.map(([label, href]) => <a href={href}>{label}</a>)}
            </div>
          </section>
        </nav>
      </div>

      <div class="evolux-footer__bottom">
        <p>&copy; {currentYear} Evolux Web Design Ltd. All rights reserved.</p>
        <p>Web Design &amp; Development · Sunderland, UK</p>
      </div>
      <div class="evolux-footer__wordmark" aria-hidden="true">
        <img src="/assets/logos/evolux-logo.svg" alt="" loading="lazy" />
      </div>
    </div>
  </section>
</footer>
