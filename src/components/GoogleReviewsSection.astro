---
import googleReviewsData from "../data/googleReviews.json";
import Icon from "./Icon.astro";

const googleReviews = googleReviewsData.reviews.filter((review) => review.text);
const googleRating = Number(googleReviewsData.rating || 5).toFixed(1);
const googleReviewCount = googleReviewsData.reviewCount || googleReviews.length;
const googleSourceUrl = googleReviewsData.sourceUrl || "https://www.google.com/search?q=Evolux+Web+Design+reviews";

const getStars = (rating) => String.fromCharCode(9733).repeat(Math.max(1, Math.min(5, Math.round(rating || 5))));
---

<section class="footer-testimonials">
  <div class="footer-testimonials__inner">
    <div class="footer-testimonials__head">
      <div>
        <div class="section-kicker"><span></span><p class="type-index">What clients say</p></div>
        <h2 class="display-heading"><span>Trusted by clients</span><br />who care about the details.</h2>
      </div>
      <div class="footer-testimonials__rating">
        <div class="google-review-mark" aria-label="Google reviews logo">
          <svg class="google-review-mark__logo" viewBox="0 0 48 48" aria-hidden="true">
            <path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3C33.7 32.7 29.3 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.9 1.2 8 3.1l5.7-5.7C34.1 6.1 29.3 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.4-.4-3.5Z"/>
            <path fill="#FF3D00" d="m6.3 14.7 6.6 4.8C14.7 15.1 19 12 24 12c3.1 0 5.9 1.2 8 3.1l5.7-5.7C34.1 6.1 29.3 4 24 4 16.3 4 9.7 8.3 6.3 14.7Z"/>
            <path fill="#4CAF50" d="M24 44c5.2 0 9.9-2 13.5-5.2l-6.2-5.2C29.3 35.1 26.8 36 24 36c-5.3 0-9.7-3.3-11.3-7.9l-6.5 5C9.5 39.5 16.2 44 24 44Z"/>
            <path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-.8 2.3-2.3 4.3-4.1 5.6l6.2 5.2C37 39.2 44 34 44 24c0-1.3-.1-2.4-.4-3.5Z"/>
          </svg>
          <span>reviews</span>
        </div>
        <div class="stars" aria-label={`${googleRating} star Google rating`}>{getStars(googleReviewsData.rating)}</div>
        <p>{googleRating} Google rating{googleReviewCount ? ` from ${googleReviewCount} reviews` : ""}</p>
      </div>
    </div>

    <div class="google-reviews-carousel" data-google-reviews-carousel>
      <div class="google-reviews-carousel__track" tabindex="0" aria-label="Google review carousel">
        {googleReviews.map((review, index) => (
          <article class:list={["testimonial-card", index === 0 && "testimonial-card--featured"]}>
            <header>
              <div class="stars" aria-label={`${review.rating} star Google review`}>{getStars(review.rating)}</div>
              <span class="testimonial-card__source">
                <svg class="google-review-mark__logo" viewBox="0 0 48 48" aria-hidden="true">
                  <path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3C33.7 32.7 29.3 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.9 1.2 8 3.1l5.7-5.7C34.1 6.1 29.3 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.4-.4-3.5Z"/>
                  <path fill="#FF3D00" d="m6.3 14.7 6.6 4.8C14.7 15.1 19 12 24 12c3.1 0 5.9 1.2 8 3.1l5.7-5.7C34.1 6.1 29.3 4 24 4 16.3 4 9.7 8.3 6.3 14.7Z"/>
                  <path fill="#4CAF50" d="M24 44c5.2 0 9.9-2 13.5-5.2l-6.2-5.2C29.3 35.1 26.8 36 24 36c-5.3 0-9.7-3.3-11.3-7.9l-6.5 5C9.5 39.5 16.2 44 24 44Z"/>
                  <path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-.8 2.3-2.3 4.3-4.1 5.6l6.2 5.2C37 39.2 44 34 44 24c0-1.3-.1-2.4-.4-3.5Z"/>
                </svg>
                Google
              </span>
            </header>
            <blockquote>"{review.text}"</blockquote>
            <footer>
              {review.companyLogo ? (
                <span class="testimonial-card__logo">
                  <img src={review.companyLogo} alt={`${review.company} logo`} loading="lazy" />
                </span>
              ) : (
                <span class="testimonial-card__logo">{review.companyInitials || review.authorInitials}</span>
              )}
              <div>
                <strong>{review.authorName}</strong>
                <p>{review.company || review.relativeTimeDescription}</p>
              </div>
            </footer>
          </article>
        ))}
      </div>
      <div class="google-reviews-carousel__footer">
        <a href={googleSourceUrl} target="_blank" rel="noreferrer">Read Evolux Google reviews <span aria-hidden="true">&#8599;</span></a>
        <div class="google-reviews-carousel__controls" aria-label="Review carousel controls">
          <button type="button" data-review-prev aria-label="Previous review"><Icon name="arrow-left" /></button>
          <button type="button" data-review-next aria-label="Next review"><Icon name="arrow-right" /></button>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    (() => {
      const carousels = document.querySelectorAll("[data-google-reviews-carousel]");
      if (!carousels.length) return;

      carousels.forEach((carousel) => {
        const track = carousel.querySelector(".google-reviews-carousel__track");
        const previous = carousel.querySelector("[data-review-prev]");
        const next = carousel.querySelector("[data-review-next]");
        if (!track || !previous || !next) return;

        const scrollReview = (direction) => {
          const firstCard = track.querySelector(".testimonial-card");
          const distance = firstCard ? firstCard.getBoundingClientRect().width + 24 : track.clientWidth * 0.85;
          track.scrollBy({ left: distance * direction, behavior: "smooth" });
        };

        previous.addEventListener("click", () => scrollReview(-1));
        next.addEventListener("click", () => scrollReview(1));
      });
    })();
  </script>
</section>
