---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import InsightsPreview from "../components/InsightsPreview.astro";
---

<BaseLayout
  title="About Joe - Founder of Evolux Web Design"
  description="Meet Joe, founder of Evolux Web Design in Sunderland, and learn how Evolux creates clearer, more credible websites for UK service businesses."
  includePersonSchema
>
  <section class="standard-hero about-hero">
    <div class="standard-hero__glow"></div>
    <div class="standard-hero__rule"></div>
    <div class="about-hero__orbit about-hero__orbit--one"></div>
    <div class="about-hero__orbit about-hero__orbit--two"></div>
    <div class="standard-hero__inner">
      <div class="blog-stamp">
        <div class="blog-stamp__crumbs">
          <a href="/" class="blog-stamp__home"><span>E</span><strong>Evolux</strong></a>
          <span>/</span>
          <strong>About</strong>
        </div>
        <div class="standard-pill">&#9733; 5.0 Google</div>
      </div>
      <div class="standard-hero__grid">
        <div data-reveal>
          <div class="mini-label"><span></span>Independent studio</div>
          <h1><span>Built differently.</span> On purpose.</h1>
          <p>Evolux is a one-person web design studio based in Sunderland, founded in 2023 on a single principle: a website should generate enquiries, not just exist.</p>
        </div>
        <aside class="about-hero__note" data-reveal>
          <p class="type-index">Founded</p>
          <strong>2023</strong>
          <p>Sunderland, Tyne & Wear<br />North East England</p>
        </aside>
      </div>
      <div class="about-hero__ticker" aria-label="Evolux studio principles">
        <div>
          <span>Strategy before styling</span><i></i>
          <span>Direct access throughout</span><i></i>
          <span>Designed in Sunderland</span><i></i>
          <span>Built for enquiries</span><i></i>
          <span aria-hidden="true">Strategy before styling</span><i aria-hidden="true"></i>
          <span aria-hidden="true">Direct access throughout</span><i aria-hidden="true"></i>
          <span aria-hidden="true">Designed in Sunderland</span><i aria-hidden="true"></i>
          <span aria-hidden="true">Built for enquiries</span><i aria-hidden="true"></i>
        </div>
      </div>
    </div>
  </section>

  <section class="about-story">
    <div class="about-story__inner">
      <aside class="founder-card about-founder-card" data-reveal>
        <div class="founder-card__wash"></div>
        <span class="founder-card__watermark">JOE</span>
        <div class="founder-card__top">
          <span>EVOLUX</span>
          <div><p class="type-index">Founder-led</p><p>Strategy, design, build</p></div>
        </div>
        <div class="about-founder-card__portrait-frame">
          <img class="about-founder-card__portrait" src="/assets/logos/joe-evolux-founder.png" alt="Joe, founder of Evolux Web Design" />
          <span class="type-index">Founder-led studio</span>
        </div>
        <div class="founder-card__body">
          <p class="type-index">Web designer & developer</p>
          <h2>Joe Evolux</h2>
          <p>5+ years turning underperforming websites into lead-generation machines. Based in Sunderland. Working across the UK.</p>
        </div>
        <div class="founder-card__stats">
          <div><strong>20+</strong><span class="type-index">projects delivered</span></div>
          <div><strong>5+</strong><span class="type-index">years experience</span></div>
          <div><span class="type-index">Based in</span><p>Sunderland, UK</p></div>
        </div>
      </aside>

      <div class="about-story__content" data-reveal>
        <div class="section-kicker"><span></span><p class="type-index">The story</p></div>
        <h2>Hey, I'm Joe.<br /><span>Founder of Evolux.</span></h2>
        <p>Evolux started in 2023 because I kept seeing the same problem: small businesses with genuinely great products and services losing enquiries to websites that looked fine but converted nobody.</p>
        <p>I'd been working in web design and development for 5 years before founding Evolux. What that time taught me is that most agencies are optimising for the wrong thing. They build sites that impress other designers, not sites that generate business for their clients.</p>
        <p>Evolux is different because conversion is the starting point, not an afterthought. Every layout decision, every heading, every call-to-action exists because it moves a visitor closer to making contact.</p>

        <div class="about-principles">
          <article data-reveal><span><Icon name="direct" /></span><div><h3>Direct access</h3><p>You work with me throughout. No account managers, no briefing documents passed down a chain.</p></div></article>
          <article data-reveal><span><Icon name="target" /></span><div><h3>Conversion first</h3><p>Every design decision is tied to one question: does this move a visitor closer to making contact?</p></div></article>
          <article data-reveal><span><Icon name="analytics" /></span><div><h3>Measured results</h3><p>I review performance after launch. The job isn't done when the site goes live.</p></div></article>
        </div>

        <div class="about-story__actions">
          <a href="/projects">Web design projects <span aria-hidden="true">&#8599;</span></a>
          <a class="button button--dark" href="/free-review">Get a free website review <span aria-hidden="true">&#8599;</span></a>
        </div>
      </div>
    </div>
  </section>

  <section class="about-video">
    <div class="about-video__inner">
      <div class="section-heading-row" data-reveal>
        <div>
          <div class="section-kicker"><span></span><p class="type-index">Watch</p></div>
          <h2><span>Two minutes on</span><br />how Evolux works.</h2>
        </div>
        <p>The thinking behind why we build websites differently, and what that means for your business.</p>
      </div>
      <div class="about-video__feature" data-reveal>
        <div class="about-video__player">
          <div class="about-video__player-meta">
            <span class="type-index">Studio note 01</span>
            <span class="type-index">02:00</span>
          </div>
          <div class="video-frame" data-about-video-card>
            <iframe
              src="about:blank"
              data-video-src="https://www.youtube-nocookie.com/embed/dWjJn7rQjNQ?rel=0&modestbranding=1&playsinline=1&autoplay=1"
              title="Evolux Web Design - How we build websites that generate enquiries"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
            <button class="video-frame__play" type="button" data-about-video-play aria-label="Play Evolux Web Design video">
              <span></span>
              <strong>Play video</strong>
            </button>
          </div>
        </div>
        <aside class="about-video__caption">
          <span class="about-video__caption-icon"><Icon name="direct" /></span>
          <p class="type-index">Inside the process</p>
          <h3>A straightforward look at how I work.</h3>
          <p>Why the work starts with your customers, where conversion thinking fits in, and what it is like to deal directly with the person building your website.</p>
          <div>
            <span><Icon name="check" /> Strategy-led</span>
            <span><Icon name="check" /> No agency layers</span>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="about-process-strip">
    <div class="about-process-strip__inner">
      <div class="section-kicker" data-reveal><span></span><p class="type-index">How I work</p></div>
      <h2 data-reveal><span>Conversion first,</span><br />everything else second.</h2>
      <div>
        {[
          ["01", "Discovery before design", "Every project starts with a deep-dive into your business, your customers, and what's stopping them from making contact."],
          ["02", "Built around your buyer", "The layout, copy hierarchy and calls-to-action are designed around your specific target customer."],
          ["03", "Launched and reviewed", "Go-live is the start, not the finish. Performance is reviewed after launch with adjustments based on behaviour."]
        ].map(([num, title, body]) => (
          <article data-reveal><span class="type-index">{num}</span><h3>{title}</h3><p>{body}</p></article>
        ))}
      </div>
    </div>
  </section>

  <section class="about-stack">
    <div class="about-stack__inner">
      <div data-reveal>
        <div class="section-kicker"><span></span><p class="type-index">The standards</p></div>
        <h2><span>The principles that</span><br />shape the work.</h2>
        <p>Every decision is judged by whether it makes the website clearer, faster, easier to trust and easier to improve after launch.</p>
      </div>
      <div class="about-stack__list" data-reveal>
        {[
          ["Clear structure", "User journeys", "Pages are organised around the way customers compare, trust and enquire."],
          ["Fast performance", "Core experience", "Images, layouts and code are kept lean so the site feels responsive on real devices."],
          ["Purposeful styling", "Design system", "No bloated visual effects. Every interaction has a reason."],
          ["Client control", "After launch", "Key content areas are planned so routine updates do not need a full rebuild."],
          ["SEO foundations", "Search visibility", "Schema markup, meta structure, performance scores and clean URLs."]
        ].map(([tool, role, desc]) => (
          <article><span><Icon name="check" /></span><div><h3>{tool}<em>{role}</em></h3><p>{desc}</p></div></article>
        ))}
      </div>
    </div>
  </section>

  <section class="about-numbers">
    <div class="about-numbers__inner">
      <div class="section-kicker" data-reveal><span></span><p class="type-index">By the numbers</p></div>
      <h2 data-reveal>Work that speaks<br /><span>for itself.</span></h2>
      <div>
        <article data-reveal><strong>20+</strong><span class="type-label">projects delivered</span></article>
        <article data-reveal><strong>5+</strong><span class="type-label">years experience</span></article>
        <article data-reveal><strong>200+</strong><span class="type-label">brands reached</span></article>
        <article data-reveal><strong>100%</strong><span class="type-label">5-star Google reviews</span></article>
      </div>
      <img src="/assets/Mockup-laptop-Marley_1779878754713.webp" alt="Marley Doulas website by Evolux" data-reveal />
    </div>
  </section>

  <InsightsPreview
    slugs={["why-websites-dont-generate-business", "brand-identity-and-web-design", "questions-to-ask-web-design-agency"]}
    headingMuted="How Joe thinks about"
    heading="better websites."
    intro="A few articles that show the Evolux approach to conversion, credibility and choosing the right web design partner."
    footerText="Evolux thinking and advice"
  />

  <section class="standard-light-cta">
    <div>
      <div class="section-kicker"><span></span><p class="type-index">A practical first step</p></div>
      <h2>Understand the website you have<br /><span>before investing in the next one.</span></h2>
      <p>Every project starts with a clear review of what is working, what is creating doubt and what would make the biggest commercial difference.</p>
    </div>
    <div>
      <a class="button button--accent" href="/free-review">Get a free website review <span aria-hidden="true">&#8599;</span></a>
      <a class="button" href="/projects">Web design projects</a>
    </div>
  </section>

  <script is:inline>
    (() => {
      const items = document.querySelectorAll("[data-reveal]");
      if (!items.length || window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        items.forEach((item) => item.classList.add("is-visible"));
        return;
      }

      document.documentElement.classList.add("has-reveal");
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        });
      }, { threshold: 0.14 });

      items.forEach((item) => observer.observe(item));
    })();

    (() => {
      const card = document.querySelector("[data-about-video-card]");
      if (!card) return;

      const button = card.querySelector("[data-about-video-play]");
      const iframe = card.querySelector("iframe[data-video-src]");
      if (!button || !iframe) return;

      button.addEventListener("click", () => {
        iframe.src = iframe.dataset.videoSrc;
        card.classList.add("video-frame--playing");
      });
    })();
  </script>
</BaseLayout>
