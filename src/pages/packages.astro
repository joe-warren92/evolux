---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import InsightsPreview from "../components/InsightsPreview.astro";
import PackageCard from "../components/PackageCard.astro";
import { createFaqSchema } from "../utils/schema";

const packages = [
  {
    id: "launch",
    name: "Launch",
    price: "\u00A31,800",
    note: "Starting from",
    tagline: "Get online with a professional site that wins you new business from day one.",
    cta: "Start with Launch",
    summary: "A focused website foundation for businesses ready to look credible and convert visitors.",
    features: ["Up to 5 custom pages", "Mobile-first responsive build", "CMS editing", "SEO foundations", "14-day support"]
  },
  {
    id: "studio",
    name: "Studio",
    price: "\u00A33,500",
    note: "Starting from",
    tagline: "The complete package - brand, website, and everything needed to grow.",
    cta: "Start with Studio",
    summary: "A fuller brand-led website for businesses that need stronger positioning and more content.",
    features: ["Up to 12 custom pages", "Brand identity system", "Conversion-led layouts", "Blog or case study setup", "30-day support"],
    highlight: true
  },
  {
    id: "elite",
    name: "Elite",
    price: "\u00A36,500",
    note: "Starting from",
    tagline: "Our most ambitious work - for businesses that want to dominate their market.",
    cta: "Talk to us about Elite",
    summary: "A deeper custom build for ambitious teams with more pages, strategy and interaction detail.",
    features: ["Up to 25 custom pages", "Advanced content planning", "Copywriting support", "Custom interactions", "90-day support"]
  }
];

const rows = [
  { category: "Your website" },
  { feature: "Designed for your business - not a template", launch: true, studio: true, elite: true },
  { feature: "Number of pages", launch: "Up to 5", studio: "Up to 12", elite: "Up to 25" },
  { feature: "Looks great on phones, tablets & desktop", launch: true, studio: true, elite: true },
  { feature: "A planning session before we start designing", launch: true, studio: true, elite: true },
  { feature: "Full brand identity - logo, colours & fonts", launch: false, studio: true, elite: true },
  { feature: "Custom animations & interactive elements", launch: false, studio: false, elite: true },
  { category: "Winning more enquiries" },
  { feature: "Every page laid out to turn visitors into leads", launch: false, studio: true, elite: true },
  { feature: "Professionally written copy for every page", launch: false, studio: false, elite: true },
  { feature: "Loads fast so visitors don't leave before reading a word", launch: "Good", studio: "Fast", elite: "Elite" },
  { feature: "Built to rank on Google from the moment it goes live", launch: "Essentials", studio: true, elite: true },
  { category: "Running your site yourself" },
  { feature: "Update your own text and images - no developer needed", launch: true, studio: true, elite: true },
  { feature: "Add news, blog posts or case studies yourself", launch: false, studio: true, elite: true },
  { feature: "Training session so you feel confident using it", launch: true, studio: true, elite: true },
  { category: "Knowing it's working" },
  { feature: "See who's visiting your site and where they came from", launch: true, studio: true, elite: true },
  { feature: "Know which pages are generating your enquiries", launch: false, studio: true, elite: true },
  { feature: "Quarterly strategy sessions to plan what's next", launch: false, studio: false, elite: true },
  { category: "After we launch" },
  { feature: "Fixes and tweaks included after go-live", launch: "14 days", studio: "30 days", elite: "90 days" },
  { feature: "If something's wrong post-launch, we fix it free", launch: false, studio: true, elite: true },
  { feature: "Same or next-day response when you need us", launch: false, studio: false, elite: true },
  { feature: "You own every design file and line of code", launch: false, studio: false, elite: true }
];

const faqs = [
  ["Which website package is right for my business?", "Launch is usually best if you need a focused, professional website with a clear offer and a small number of pages. Studio suits businesses that need stronger positioning, brand identity and a deeper site structure. Elite is for teams that need more pages, copy support, advanced content planning and a more distinctive digital presence. If you are unsure, start with a <a href=\"/free-review\">free website review</a> so Joe can recommend the sensible starting point."],
  ["Are the package prices fixed or will the cost change later?", "The prices are starting points for clearly defined scopes, not open-ended estimates. Before work begins, you receive a written proposal confirming pages, deliverables, timeline, support period and optional extras such as copywriting, <a href=\"/services/branding\">brand identity</a>, SEO landing pages or advanced functionality. Once the scope is agreed, what is quoted is what you pay."],
  ["What is included before the design work starts?", "Every package includes planning before design begins. That covers your business goals, audience, competitors, services, tone of voice, current website performance and what visitors need to do next. This creates the strategy behind the page structure, calls to action and SEO foundations. For more detail on the full build process, see the <a href=\"/services/web-design\">web design service</a>."],
  ["Should I choose Studio or Elite?", "Studio is ideal if you need a polished, brand-led website with conversion-focused layouts, a professional identity system and enough content depth to explain your offer properly. Elite goes further with more pages, deeper copy and content planning, custom interaction details, more advanced SEO structure and a longer post-launch support window. It is the better fit when your website needs to support a stronger market position, not just replace an old site."],
  ["Can I start with Launch and improve the website later?", "Yes. Launch is designed as a credible foundation for businesses that need a professional site quickly. If your business grows, Evolux can add service pages, case studies, SEO content, stronger proof, conversion improvements or a wider redesign later. You can also use the <a href=\"/services/conversion-optimisation\">conversion optimisation</a> service to improve an existing site before committing to a bigger rebuild."],
  ["Do the packages include SEO?", "Every package includes SEO foundations such as clean page structure, metadata, headings, image optimisation and indexable pages. Studio and Elite allow more room for deeper service pages, case studies and content structure, which is usually what helps businesses compete for better searches. If you are comparing prices, the article on <a href=\"/insights/understanding-website-costs-in-2025\">website costs</a> explains why scope and strategy matter more than page count alone."]
];

const renderCell = (value: boolean | string | undefined) => {
  if (value === true) return "\u2713";
  if (value === false) return "-";
  return value;
};
const faqSchema = createFaqSchema("https://evoluxwebdesign.co.uk/packages/#faq", faqs);
---

<BaseLayout
  title="Website Design Packages & Pricing | Evolux"
  description="Compare Evolux website design packages, pricing and deliverables. Choose a focused launch site, a strategic studio build or a premium custom project."
  structuredData={faqSchema}
>
  <section class="packages-hero">
    <div class="packages-hero__glow packages-hero__glow--one"></div>
    <div class="packages-hero__glow packages-hero__glow--two"></div>
    <div class="packages-hero__rule"></div>
    <div class="packages-hero__inner">
      <div class="blog-stamp">
        <div class="blog-stamp__crumbs">
          <a href="/" class="blog-stamp__home"><span>E</span><strong>Evolux</strong></a>
          <span>/</span>
          <strong>Packages</strong>
        </div>
      </div>

      <div class="packages-hero__grid">
        <div class="packages-hero__copy">
          <div class="mini-label"><span></span>Website packages</div>
          <h1><span>Transparent pricing.</span> No surprises.</h1>
          <p>A clear starting point for a website investment that is properly scoped around your business. Choose the level that fits where you are now, then know exactly what is included before work begins.</p>
          <div class="packages-hero__actions">
            <a class="button button--accent" href="#packages">Compare packages</a>
            <a class="text-button" href="/free-review">Start with a free review <span aria-hidden="true">&#8599;</span></a>
          </div>
        </div>
        <aside class="packages-hero__starting-point" aria-label="Website package starting price">
          <p class="type-index">Website projects from</p>
          <strong>&pound;1,800</strong>
          <span>Every proposal is confirmed in writing before the design work starts.</span>
        </aside>
      </div>

      <div class="packages-hero__assurances" aria-label="What to expect">
        <div>
          <span class="packages-hero__assurance-icon"><Icon name="document" /></span>
          <div>
            <strong>Clear scope</strong>
            <p>Pages, functionality and support agreed upfront.</p>
          </div>
        </div>
        <div>
          <span class="packages-hero__assurance-icon"><Icon name="direct" /></span>
          <div>
            <strong>Direct process</strong>
            <p>Work directly with Joe from first call to launch.</p>
          </div>
        </div>
        <div>
          <span class="packages-hero__assurance-icon"><Icon name="growth" /></span>
          <div>
            <strong>Room to grow</strong>
            <p>Start at the sensible level and build from there.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="packages-cards-section" id="packages">
    <div class="packages-cards-section__inner">
      <div class="packages-cards-section__head">
        <div>
          <div class="section-kicker"><span></span><p class="type-index">Website packages</p></div>
          <h2><span>Choose the right level</span><br />for where you are now.</h2>
        </div>
        <p>Each package follows the same strategy-led process. The difference is depth: pages, positioning, brand support, content and the amount of post-launch help included.</p>
      </div>
      <div class="package-grid packages-page-card-grid">
        {packages.map((pkg) => (
          <PackageCard
            id={pkg.id}
            name={pkg.name}
            tagline={pkg.tagline}
            price={pkg.price}
            features={pkg.features}
            highlight={pkg.highlight}
            note={pkg.note}
          />
        ))}
      </div>

      <div class="packages-guarantee">
        <span><Icon name="shield" /></span>
        <p><strong>Something wrong after launch?</strong> On Studio and Elite, we fix it free - no questions asked. 30 days on Studio, 90 days on Elite.</p>
        <a href="/free-review">Review my website first <span aria-hidden="true">&#8599;</span></a>
      </div>
    </div>
  </section>

  <section class="service-industry-cta packages-industry-cta">
    <div class="service-industry-cta__content">
      <div class="section-kicker"><span></span><p class="type-index">Industry-focused planning</p></div>
      <h2><span>The right package</span> depends on the buying journey.</h2>
      <p>A clinic, accountant, recruitment agency and trades business do not need the same website structure. The package should reflect how your audience builds trust, compares options and decides whether to get in touch.</p>
    </div>
    <div class="service-industry-cta__aside">
      <ul>
        <li><span>01</span><strong>Trust requirements</strong><em>Choose the depth of proof your buyers need before they enquire.</em></li>
        <li><span>02</span><strong>Content depth</strong><em>Plan the pages needed to explain services clearly without bloating the site.</em></li>
        <li><span>03</span><strong>Commercial fit</strong><em>Match the scope to the value of the enquiries the website needs to create.</em></li>
      </ul>
      <a class="button button--dark" href="/industries">Explore industry website guides <span aria-hidden="true">&#8599;</span></a>
    </div>
  </section>

  <section class="comparison-section" id="comparison">
    <div class="comparison-section__inner">
      <div class="section-heading-row comparison-section__head">
        <div>
          <div class="section-kicker"><span></span><p class="type-index">Full comparison</p></div>
          <h2><span>What's included</span><br />in each package.</h2>
        </div>
        <p>Compare the practical differences in page depth, brand support, enquiry planning, SEO foundations and launch support before choosing a scope.</p>
      </div>

      <div class="comparison-table" aria-label="Package comparison table">
        <div class="comparison-table__head">
          <span>Feature</span>
          {packages.map((pkg) => <strong>{pkg.name}<br /><em>{pkg.price}</em></strong>)}
        </div>
        {rows.map((row) => (
          "category" in row
            ? <div class="comparison-table__category"><span>{row.category}</span></div>
            : <div class="comparison-table__row">
                <p>{row.feature}</p>
                <span class:list={[row.launch === true && "comparison-table__check", row.launch === false && "comparison-table__dash"]}>{renderCell(row.launch)}</span>
                <span class:list={["comparison-table__studio", row.studio === true && "comparison-table__check", row.studio === false && "comparison-table__dash"]}>{renderCell(row.studio)}</span>
                <span class:list={[row.elite === true && "comparison-table__check", row.elite === false && "comparison-table__dash"]}>{renderCell(row.elite)}</span>
              </div>
        ))}
      </div>

      <div class="comparison-mobile">
        {packages.map((pkg) => (
          <article class:list={["comparison-mobile-card", pkg.highlight && "comparison-mobile-card--featured"]}>
            <header>
              <p class="type-label">{pkg.name}</p>
              <h3>{pkg.price}</h3>
              <span class="type-index">{pkg.note}</span>
            </header>
            <div>
              {rows.filter((row) => !("category" in row)).map((row) => {
                const value = row[pkg.id as "launch" | "studio" | "elite"];
                return value !== false && (
                  <p><span><Icon name="check" /></span>{row.feature}{typeof value === "string" ? ` - ${value}` : ""}</p>
                );
              })}
            </div>
            <a href="/contact">{pkg.cta} <span aria-hidden="true">&#8599;</span></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="packages-testimonial">
    <article>
      <div class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
      <blockquote>"From the outset Joe checked in regularly, asked about my preferences, and turned my ideas into a slick, classic, professional site."</blockquote>
      <footer><span>SK</span><div><strong>Sara Knight</strong><em>Sara Knight Life Coaching</em></div></footer>
    </article>
  </section>

  <InsightsPreview
    slugs={["understanding-website-costs-in-2025", "real-cost-of-cheap-website", "questions-to-ask-web-design-agency"]}
    headingMuted="Better context for"
    heading="website pricing."
    intro="These articles explain how to compare website costs, avoid false economies and understand what a serious web design project should include."
    footerText="Pricing and planning articles"
  />

  <section class="review-faq packages-faq">
    <div class="review-faq__inner">
      <div class="faq-support-card">
        <div class="section-kicker"><span></span><p class="type-index">FAQs</p></div>
        <h2>Scope, pricing and fit.</h2>
        <div class="faq-support-card__person">
          <img src="/assets/logos/joe-evolux-founder.png" alt="Joe, founder of Evolux Web Design" loading="lazy" />
          <div><strong>Want a steer first?</strong><span>Ask Joe directly.</span></div>
        </div>
        <a class="button button--dark" href="/free-review">Website review</a>
      </div>
      <div class="faq-accordion-list">
        {faqs.map(([q, a]) => <details><summary>{q}</summary><p set:html={a}></p></details>)}
      </div>
    </div>
  </section>

  <section class="service-dark-cta packages-cta">
    <div>
      <div class="section-kicker"><span></span><p class="type-index">Scope before spend</p></div>
      <h2>Find the right level of website investment.</h2>
      <p>A free website review will show what your current site is missing, which improvements matter most and which package is likely to be proportionate.</p>
      <div>
        <a class="button button--accent" href="/free-review">Free website review</a>
        <a href="/contact">Contact Joe directly <span aria-hidden="true">&#8599;</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
