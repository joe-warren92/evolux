---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import InsightsPreview from "../../components/InsightsPreview.astro";
import { PROJECTS } from "../../data/projects";

export function getStaticPaths() {
  return PROJECTS.map((project) => ({ params: { slug: project.slug }, props: { project } }));
}

const { project } = Astro.props;
const projectSeoDescriptions: Record<string, string> = {
  "circular-branding": "See how Evolux redesigned the Circular Branding Group website to strengthen trade credibility, showcase its portfolio and support higher-quality B2B enquiries.",
  "marley-doulas": "See how Evolux created a calm, trust-led website for Marley Doulas, with clearer services and a more reassuring enquiry journey for expectant parents.",
  "ockerby-academy": "See how Evolux designed the Ockerby Academy website around clearer class discovery, stronger local credibility and simpler enquiries for parents.",
  "manton-executives": "See how Evolux created a premium recruitment website for Manton Executives, with clearer candidate and employer journeys and stronger positioning.",
  "pro-pest-manchester": "See how Evolux rebuilt the Pro Pest Manchester website with clearer pest control services, stronger local trust signals and a faster estimate enquiry journey."
};

const quoteText = project.testimonial ?? project.projectQuote;
const quoteName = project.testimonialName ?? project.projectQuoteAttribution ?? "Project focus";
const quoteCompany = project.testimonialCompany;
---

<BaseLayout
  title={`${project.title} - Case Study | Evolux Web Design`}
  description={projectSeoDescriptions[project.slug] ?? project.description}
  canonicalPath={`/projects/${project.slug}`}
>
  <section class="case-study-hero">
    <div class="case-study-hero__inner">
      <nav class="case-study-crumbs" aria-label="Breadcrumb">
        <a href="/projects">Web design projects</a>
        <span>/</span>
        <strong>{project.title}</strong>
      </nav>
      <div class="case-study-hero__grid">
        <div>
          <div class="mini-label"><span></span>{project.category}</div>
          <h1>{project.title}</h1>
          <p>{project.description}</p>
          <div class="case-study-hero__actions">
            {project.liveUrl && (
              <a class="button button--accent" href={project.liveUrl} target="_blank" rel="noopener noreferrer">
                View live website <span aria-hidden="true">&#8599;</span>
              </a>
            )}
            <a class="text-button" href="/projects">Back to projects <span aria-hidden="true">&#8599;</span></a>
          </div>
        </div>
        <dl class="case-meta">
          {project.meta.map(([label, value]) => (
            <div><dt>{label}</dt><dd>{value}</dd></div>
          ))}
        </dl>
      </div>
    </div>
    <figure class="case-study-hero__image">
      <img src={project.hero} alt={`${project.title} website mockup`} />
    </figure>
  </section>

  <section class="case-study-summary">
    <div class="case-study-summary__inner">
      <div class="case-study-summary__intro">
        <div class="section-kicker"><span></span><p class="type-index">Case study</p></div>
        <h2>A website shaped around {project.resultLabel}.</h2>
        <p>{project.challenge}</p>
      </div>
      <div class="case-study-summary__points" aria-label="Project focus areas">
        {project.outcomes.map((item) => (
          <article>
            <span>{item.metric}</span>
            <p>{item.label}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="case-overview">
    <div class="case-overview__inner">
      <div class="case-overview__copy">
        <div class="section-kicker"><span></span><p class="type-index">The brief</p></div>
        <h2>{project.briefTitle}</h2>
        {project.brief.map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <aside class="case-deliverables">
        <p class="type-label">What was delivered</p>
        <ul>
          {project.deliverables.map((item) => <li><span><Icon name="check" /></span>{item}</li>)}
        </ul>
      </aside>
    </div>
  </section>

  <section class="case-split-section">
    <div class="case-split-section__inner">
      <article>
        <span class="type-label">01 - The challenge</span>
        <h2>{project.challengeTitle}</h2>
        <p>{project.challenge}</p>
      </article>
      <article>
        <span class="type-label">02 - The solution</span>
        <h2>{project.solutionTitle}</h2>
        <p>{project.solution}</p>
      </article>
    </div>
  </section>

  {quoteText && (
    <section class="case-quote-section">
      <div class="case-quote-section__inner">
        <figure class="case-quote">
          <span class="case-quote__mark" aria-hidden="true">"</span>
          <blockquote>
            <p>"{quoteText}"</p>
            <footer>
              <strong>{quoteName}</strong>
              {quoteCompany && <span>{quoteCompany}</span>}
            </footer>
          </blockquote>
        </figure>
        <aside class="case-quote-section__link">
          <p class="type-label">Live project</p>
          <h2>See the finished website in context.</h2>
          <p>Review the live site to see how the structure, visual hierarchy and enquiry routes work together outside a mockup.</p>
          {project.liveUrl && (
            <a class="button button--dark" href={project.liveUrl} target="_blank" rel="noopener noreferrer">
              Open live website <span aria-hidden="true">&#8599;</span>
            </a>
          )}
        </aside>
      </div>
    </section>
  )}

  <section class="case-screens">
    <div class="case-screens__inner">
      <div class="section-kicker"><span></span><p class="type-index">Selected screens</p></div>
      <div class="case-screens__grid">
        {project.screens.map((screen) => (
          <figure>
            <img src={screen} alt={`${project.title} screen`} />
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="case-results">
    <div class="case-results__glow"></div>
    <div class="case-results__inner">
      <div class="section-kicker"><span></span><p class="type-index">Outcomes</p></div>
      <h2>{project.outcomeTitle}</h2>
      <div class="case-results__grid">
        {project.outcomes.map((item) => (
          <article><strong>{item.metric}</strong><span class="type-label">{item.label}</span></article>
        ))}
      </div>
      <div class="case-results__quote">
        <p>Want the same level of thinking applied to your own website? Start with a free review and Joe will show where the strongest opportunities sit.</p>
        <a class="button button--accent" href="/free-review">Get a free website review <span aria-hidden="true">&#8599;</span></a>
      </div>
    </div>
  </section>

  <InsightsPreview
    slugs={["why-websites-dont-generate-business", "brand-identity-and-web-design", "6-things-that-kill-website-conversion-rate"]}
    headingMuted="Related thinking from"
    heading="the Evolux process."
    intro="A few practical articles that explain the conversion, credibility and positioning decisions behind projects like this."
    footerText="Case study related articles"
  />

  <section class="case-next">
    <div>
      <p class="type-label">Plan the next move</p>
      <h2>Build around the decision<br /><span>your customers need to make.</span></h2>
      <p>Every Evolux project starts with a clear look at what is working, what is creating doubt and what needs to change.</p>
    </div>
    <div>
      <a class="button button--accent" href="/free-review">Get a free website review <span aria-hidden="true">&#8599;</span></a>
      {project.liveUrl && <a class="button" href={project.liveUrl} target="_blank" rel="noopener noreferrer">View live website</a>}
      <a class="button" href="/projects">Web design projects</a>
    </div>
  </section>
</BaseLayout>
