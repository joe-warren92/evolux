---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import InsightsPreview from "../../components/InsightsPreview.astro";
import { PROJECTS } from "../../data/projects";

const [featured, ...rest] = PROJECTS;
const heroVisuals = PROJECTS.flatMap((project) => [
  { title: project.title, image: project.hero, category: project.category },
  ...project.screens.slice(0, 1).map((image) => ({ title: project.title, image, category: project.industry }))
]);
const visualTrack = [...heroVisuals, ...heroVisuals];
---

<BaseLayout
  title="Web Design Projects & Case Studies | Evolux"
  description="Explore web design projects by Evolux, including websites for service businesses, healthcare, education, B2B suppliers and growing UK brands."
>
  <section class="portfolio-hero">
    <div class="portfolio-hero__glow"></div>
    <div class="portfolio-hero__rule"></div>
    <div class="portfolio-hero__inner">
      <div class="blog-stamp">
        <div class="blog-stamp__crumbs">
          <a href="/" class="blog-stamp__home"><span>E</span><strong>Evolux</strong></a>
          <span>/</span>
          <strong>Projects</strong>
        </div>
      </div>
      <div class="portfolio-hero__visual-belt" aria-hidden="true">
        <div class="portfolio-hero__visual-track">
          {visualTrack.map((item) => (
            <figure class="portfolio-hero__visual">
              <img src={item.image} alt="" loading="lazy" />
              <span><strong>{item.title}</strong><em>{item.category}</em></span>
            </figure>
          ))}
        </div>
      </div>
      <div class="portfolio-hero__grid">
        <div>
          <h1><span>Selected work,</span> with the thinking behind it.</h1>
          <p>A closer look at websites shaped around trust, clarity and better enquiry journeys for service-led businesses.</p>
        </div>
        <aside class="portfolio-hero__note">
          <p class="type-index">Project thinking</p>
          <h2>Not a gallery. A record of commercial decisions.</h2>
          <p>Each project is shaped around the point where a visitor decides whether the business feels credible enough to contact.</p>
          <dl>
            <div>
              <dt>Focus</dt>
              <dd>Trust before enquiry</dd>
            </div>
            <div>
              <dt>Evidence</dt>
              <dd>Real sites for real businesses</dd>
            </div>
          </dl>
        </aside>
      </div>
    </div>
  </section>

  <section class="portfolio-featured">
    <div class="portfolio-featured__inner">
      <a class="portfolio-featured-card" href={`/projects/${featured.slug}`}>
        <figure>
          <img src={featured.hero} alt={featured.title} />
          <figcaption>
            <div>
              <p class="type-index">{featured.category}</p>
              <strong>{featured.title}</strong>
            </div>
            <span><Icon name="arrow" /></span>
          </figcaption>
          <em>{featured.num} - Selected project</em>
        </figure>
        <div class="portfolio-featured-card__meta">
          <div>
            <p class="type-label">{featured.category}</p>
            <h2>{featured.title}</h2>
            <p>{featured.cardOutcome ?? featured.description}</p>
          </div>
          <dl>
            <div><dt>Client type</dt><dd>{featured.clientType}</dd></div>
            <div><dt>Year</dt><dd>{featured.year}</dd></div>
          </dl>
          <div class="portfolio-featured-card__result">
            <strong>{featured.result}</strong>
            <span>{featured.resultLabel}</span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <section class="portfolio-grid-section">
    <div class="portfolio-grid-section__inner">
      <div class="portfolio-grid">
        {rest.map((project) => (
          <article class="portfolio-card">
            <a href={`/projects/${project.slug}`}>
              <figure>
                <img src={project.hero} alt={project.title} />
                <figcaption>
                  <p class="type-index">{project.category}</p>
                  <strong>{project.title}</strong>
                </figcaption>
                <em>{project.num}</em>
              </figure>
              <div>
                <div>
                  <h2>{project.title}</h2>
                  <span class="portfolio-card__focus">{project.result}</span>
                </div>
                <p class="type-index">{project.industry} &middot; {project.year}</p>
                <p>{project.cardOutcome}</p>
                <strong class="portfolio-card__link-text">Read case study</strong>
              </div>
            </a>
          </article>
        ))}
      </div>
      <div class="portfolio-footnote">
        <p class="type-index">Selected examples of recent Evolux project work</p>
        <p class="type-index">Sunderland, Tyne & Wear - est. 2023</p>
      </div>
    </div>
  </section>

  <InsightsPreview
    slugs={["why-websites-dont-generate-business", "template-vs-bespoke-web-design-sunderland", "brand-identity-and-web-design"]}
    headingMuted="The thinking behind"
    heading="better website projects."
    intro="These articles explain the strategy behind clearer positioning, stronger proof and websites that make it easier for the right people to enquire."
    footerText="Project strategy articles"
  />

  <section class="archive-cta">
    <svg aria-hidden="true" viewBox="0 0 380 380">
      <circle cx="320" cy="320" r="200"></circle>
      <circle cx="320" cy="320" r="110"></circle>
    </svg>
    <div>
      <p class="type-index"><span></span>Plan the next improvement</p>
      <h2>Bring the same level of thinking to your own website.</h2>
      <p>Start with a free website review and Joe will show where trust, clarity or conversion friction is holding your current site back.</p>
      <div>
        <a class="button button--accent" href="/free-review">Free website review</a>
        <a href="/packages">Website packages <span aria-hidden="true">&#8594;</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
