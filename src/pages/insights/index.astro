---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ALL_CATEGORIES, INSIGHT_POSTS, JOE_AUTHOR } from "../../data/insights";

const topics = [
  {
    title: "Conversion strategy",
    description: "Why most websites don't convert, and the layout, copy, and UX decisions that change that."
  },
  {
    title: "Web design for small business",
    description: "Practical advice on briefs, timelines, budgets, and choosing the right builder for your needs."
  },
  {
    title: "Local SEO & visibility",
    description: "How to rank for the searches your customers are actually making, without paying for ads."
  },
  {
    title: "The business case for investment",
    description: "The honest maths of web design ROI: when a new site pays for itself, and when it doesn't."
  }
];

const formatDate = (date) =>
  new Date(date).toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });

const postsByDate = [...INSIGHT_POSTS].sort(
  (a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime()
);
---

<BaseLayout title="Insights - Web Design & Business Strategy">
  <section class="blog-hero">
    <div class="blog-hero__inner">
      <div class="blog-stamp">
        <div class="blog-stamp__crumbs">
          <a href="/" class="blog-stamp__home"><span>E</span><strong>Evolux</strong></a>
          <span>/</span>
          <strong>Insights</strong>
        </div>
        <div class="blog-author-chip">
          <img src={JOE_AUTHOR.image} alt="" />
          <strong>{JOE_AUTHOR.name}</strong>
          <em>Monthly</em>
        </div>
      </div>

      <div class="blog-hero__grid">
        <h1><span>Straight talk about</span><br />web design &amp; business.</h1>
        <p>We write about the decisions that grow businesses - conversion, strategy, and the honest maths of web investment.</p>
      </div>
    </div>
  </section>

  <section class="blog-topics">
    <div class="blog-topics__inner">
      <div class="section-kicker"><span></span><p class="type-index">What we write about</p></div>
      <div class="blog-topics__grid">
        {topics.map((topic) => (
          <article class="blog-topic-card">
            <h2>{topic.title}</h2>
            <p>{topic.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="blog-filter" data-blog-filter>
    <div class="blog-filter__inner">
      <div class="blog-filter__buttons">
        {ALL_CATEGORIES.map((category, index) => (
          <button class:list={["blog-filter__button", index === 0 && "blog-filter__button--active"]} type="button" data-category={category}>
            {category}
          </button>
        ))}
      </div>
      <span class="type-label" data-article-count>{postsByDate.length} articles</span>
    </div>
  </section>

  <section class="blog-archive">
    <div class="blog-archive__inner">
      <div class="blog-archive__grid">
        {postsByDate.map((post, index) => (
          <article class="blog-card" data-post-card data-category={post.category}>
            <a href={`/insights/${post.slug}`}>
              <div class="blog-card__cover">
                {post.heroImage && <img src={post.heroImage} alt="" loading="lazy" />}
                <div class="blog-card__bloom"></div>
                <span class="blog-card__number">{String(index + 1).padStart(2, "0")}</span>
                <div class="blog-card__top">
                  <span>{post.category}</span>
                  <span>{post.readingTime} min read</span>
                </div>
              </div>
              <div class="blog-card__body">
                <h2>{post.title}</h2>
                <div class="blog-card__meta">
                  <div>
                    <img src={JOE_AUTHOR.image} alt="" loading="lazy" />
                    <div>
                      <strong>{JOE_AUTHOR.name}</strong>
                      <time datetime={post.publishedAt}>{formatDate(post.publishedAt)}</time>
                    </div>
                  </div>
                  <span aria-hidden="true">&#8599;</span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="blog-author-strip">
    <div class="blog-author-strip__inner">
      <img class="blog-author-strip__avatar" src={JOE_AUTHOR.image} alt="Joe, founder of Evolux Web Design" loading="lazy" />
      <div>
        <h2>{JOE_AUTHOR.name} - {JOE_AUTHOR.role}</h2>
        <p>{JOE_AUTHOR.bio}</p>
      </div>
      <a href="/about">Read about Joe, founder of Evolux <span aria-hidden="true">&#8599;</span></a>
    </div>
  </section>

  <script is:inline>
    (() => {
      const root = document.querySelector("[data-blog-filter]");
      if (!root) return;

      const buttons = Array.from(root.querySelectorAll("[data-category]"));
      const cards = Array.from(document.querySelectorAll("[data-post-card]"));
      const count = root.querySelector("[data-article-count]");

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          const category = button.dataset.category;
          let visible = 0;

          buttons.forEach((item) => item.classList.toggle("blog-filter__button--active", item === button));
          cards.forEach((card) => {
            const show = category === "All" || card.dataset.category === category;
            card.hidden = !show;
            if (show) visible += 1;
          });

          if (count) count.textContent = `${visible} article${visible === 1 ? "" : "s"}`;
        });
      });
    })();
  </script>
</BaseLayout>
