---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/site";
import { JOE_AUTHOR } from "../data/insights";
import Icon from "../components/Icon.astro";
import InsightsPreview from "../components/InsightsPreview.astro";
import PackageCard from "../components/PackageCard.astro";
import { stripHtml } from "../utils/schema";

const packages = [
  {
    id: "launch",
    name: "Launch",
    tagline: "For businesses that need a credible first impression, delivered quickly.",
    price: "&pound;1,800",
    features: [
      "5-page custom design & build",
      "Mobile-first, fully responsive",
      "Brand alignment session",
      "CMS - edit copy yourself",
      "Core SEO setup",
      "14-day post-launch support"
    ],
    cta: "Start with Launch"
  },
  {
    id: "studio",
    name: "Studio",
    tagline: "The full package for brands serious about growth.",
    price: "&pound;3,500",
    features: [
      "Up to 12 custom pages",
      "Full visual identity system",
      "Conversion-optimised layouts",
      "Advanced SEO & Core Web Vitals",
      "Headless CMS integration",
      "Analytics & goal tracking",
      "30-day post-launch support",
      "Monthly strategy review"
    ],
    cta: "Start with Studio",
    highlight: true
  },
  {
    id: "elite",
    name: "Elite",
    tagline: "For businesses that want the very best - no compromises, no limits.",
    price: "&pound;6,500",
    features: [
      "Up to 25 fully custom pages",
      "Complete brand identity system",
      "Custom animations & interactions",
      "Conversion-led copywriting",
      "Advanced SEO & analytics setup",
      "90-day post-launch support",
      "Quarterly strategy sessions",
      "You own every file and line of code"
    ],
    cta: "Talk to us about Elite"
  }
];

const credibilityGaps = [
  {
    num: "01",
    question: "Does your website reflect the quality of your work within the first 10 seconds?",
    problem: "Your website doesn't reflect the quality of your work within the first 10 seconds.",
    benefit: "You make a stronger first impression with the clients you actually want to attract."
  },
  {
    num: "02",
    question: "Can potential clients quickly understand whether you're the right fit?",
    problem: "Potential clients can't quickly understand whether you're the right fit.",
    benefit: "Clear positioning helps the right people feel confident taking the next step."
  },
  {
    num: "03",
    question: "Do your claims have enough proof behind them?",
    problem: "You say the right things, but don't show enough proof to make them believable.",
    benefit: "Reviews, case studies and details in the right places help people trust you before they get in touch."
  },
  {
    num: "04",
    question: "Is there an obvious next step for visitors on every page?",
    problem: "There isn't an obvious next step, so visitors leave without getting in touch.",
    benefit: "Every key page gives people a clear, low-friction route to enquire."
  }
];

const homepageFaqs = [
  ["Can Evolux help if my website looks fine but does not bring in enough enquiries?", "Yes. This is one of the most common reasons businesses contact Evolux. The issue is often not the visual design alone; it is usually a mix of unclear positioning, weak proof, poor page structure, slow mobile experience or calls to action that do not feel obvious. A good starting point is the <a href=\"/free-review\">free website review</a>, where Joe identifies the main trust and conversion gaps before you commit to a full redesign."],
  ["Do you design and build the website, or just create the visuals?", "Evolux handles both the design and the build. You work directly with Joe from strategy and page planning through to design, development, testing and launch. That means the finished site is not just a static concept; it is a fast, responsive, editable website built around clear business goals. You can see the main service options on the <a href=\"/services\">web design services</a> page."],
  ["What types of businesses are a good fit for Evolux?", "Evolux is best suited to service-based businesses, local companies and growing UK brands that rely on trust before someone makes an enquiry. That includes professional services, recruitment, health and wellness, trades, education, hospitality and B2B suppliers. If you want to see the kind of work and outcomes Evolux focuses on, start with the <a href=\"/projects\">web design projects</a>."],
  ["How much should I budget for a professional website?", "Most Evolux website projects start from the figures shown on the <a href=\"/packages\">website packages</a> page. The final investment depends on the number of pages, how much content needs writing, whether brand identity is included, SEO requirements and the level of post-launch support. Before anything starts, you receive a written scope so the deliverables, timeline and cost are clear."],
  ["Can you improve my existing website instead of rebuilding it?", "Sometimes, yes. If the underlying site is technically sound, a focused <a href=\"/services/conversion-optimisation\">conversion optimisation</a> project may be enough to improve enquiries without starting again. If the structure, brand, platform or mobile experience is holding the business back, a rebuild may be the better long-term option. The review process helps make that decision with evidence rather than guesswork."],
  ["How quickly can a new website project start?", "Availability changes depending on current projects, but the first step is usually a short message, a call or a <a href=\"/free-review\">website review</a>. From there, Joe can confirm whether the project is a good fit, what timeline is realistic and which package or scope makes most sense. Focused Launch projects can move quickly; larger Studio or Elite projects need more discovery, content and design time."]
];

const trustedLogos = [
  { name: "Skyn & Glo", image: "/assets/logos/skyn-glo-logo.webp" },
  { name: "Ockerby Academy", image: "/assets/logos/ockerby-academy-logo.webp" },
  { name: "Circular Branding", image: "/assets/logos/circular-branding-logo.webp" },
  { name: "Manton Executives", image: "/assets/logos/manton-executives-logo.webp" }
];

const homepageSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": "https://evoluxwebdesign.co.uk/#credibility-gap-faq",
  mainEntity: [
    ...credibilityGaps.map((gap) => ({
    "@type": "Question",
    name: gap.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: gap.benefit
    }
    })),
    ...homepageFaqs.map(([question, answer]) => ({
      "@type": "Question",
      name: question,
      acceptedAnswer: {
      "@type": "Answer",
        text: stripHtml(answer)
      }
    }))
  ]
};
---

<BaseLayout
  title="Web Design Sunderland | Websites That Generate Enquiries"
  description="Sunderland web design studio creating conversion-focused websites for service businesses that need to build trust, win enquiries and grow online."
  structuredData={homepageSchema}
  includeFounderSchema
  includePersonSchema
>
  <section class="home-hero">
    <div class="home-hero__glow home-hero__glow--one"></div>
    <div class="home-hero__glow home-hero__glow--two"></div>
    <div class="home-hero__rule"></div>

    <div class="home-hero__inner">
      <div class="home-hero__stamp">
        <div class="home-hero__identity">
          <span class="type-index">Evolux Web Design</span>
          <span class="home-hero__dot"></span>
          <span class="type-index home-hero__location">Sunderland, UK · Est. 2023</span>
        </div>
      </div>

      <h1 class="home-hero__title">
        <span>Websites built to win</span>
        <span><em>enquiries,</em> <strong class="home-hero__title-muted">not just traffic.</strong></span>
      </h1>

      <div class="home-hero__grid">
        <div>
          <p class="home-hero__text">
            Conversion-focused web design in Sunderland for service businesses that need to build trust and generate better enquiries. Evolux turns credibility into enquiries through sharper positioning,
            clearer page structure and fewer moments of doubt between first impression and contact.
          </p>
          <div class="home-hero__actions">
            <a class="button button--accent" href="/contact"><span></span>Book a strategy call</a>
            <a class="text-button" href="/free-review">Get a free website review <span aria-hidden="true">&#8599;</span></a>
          </div>
          <div class="home-hero__review-signal" aria-label="Google review rating">
            <span class="stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <span>5.0 Google rating from local businesses</span>
          </div>
          <div class="home-hero__clients">
            <p class="type-index">Trusted by</p>
            <div class="home-hero__logo-rail" aria-label="Trusted by client logos">
              <div class="home-hero__logo-track">
                {[...trustedLogos, ...trustedLogos].map((logo) => (
                  <span class="home-hero__logo">
                    <img src={logo.image} alt={logo.name} loading="eager" />
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>

        <figure class="home-hero__quote">
          <img src="/assets/logos/steven-dunn-circular-branding.jpg" alt="Steven Dunn, Circular Branding Group" loading="eager" />
          <blockquote>"The result says it all. Clear communication throughout, proactive, responsive, and attention to detail was second to none."</blockquote>
          <figcaption>
            <strong>Steven Dunn</strong>
            <p>Circular Branding Group</p>
          </figcaption>
        </figure>
      </div>
    </div>

    <div class="hero-showcase">
      <img src="/assets/Screenshot-2025-02-14-at-20.27.41_(3)_1779878754711.webp" alt="Selection of Evolux client websites" />
      <div class="hero-showcase__shade"></div>
      <div class="hero-showcase__content">
        <div>
          <div class="avatar-row">
            <span>CB</span><span>ME</span><span>OA</span>
          </div>
          <div>
            <div class="stars stars--light">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <p class="type-index">20+ clients served</p>
          </div>
        </div>
        <div class="hero-showcase__region">
          <strong>UK-wide</strong>
          <p class="type-index">clients served</p>
        </div>
        <p class="type-index">Evolux Web Design</p>
      </div>
    </div>
  </section>

  <section class="featured-work" id="work">
    <div class="section-split">
      <div>
        <div class="section-kicker"><span></span><p class="type-index">Selected projects</p></div>
        <h2 class="display-heading"><span>Selected work</span><br />with a clear purpose.</h2>
      </div>
      <p>Recent websites shaped around clearer positioning, stronger trust signals and a more useful route to enquiry.</p>
    </div>

    <div class="work-grid">
      {projects.map((project, index) => (
        <article class:list={["work-card", index % 2 === 1 && "work-card--lower"]}>
          <a href={`/projects/${project.slug}`} class="work-card__link">
            <figure class:list={["work-card__media", index % 2 === 1 && "work-card__media--portrait"]}>
              <img src={project.image} alt={project.title} />
              <figcaption>
                <div>
                  <p class="type-index">{project.category}</p>
                  <strong>{project.title}</strong>
                </div>
                <span>&#8599;</span>
              </figcaption>
            </figure>
            <div class="work-card__meta">
              <div>
                <span class="type-index">{String(index + 1).padStart(2, "0")}</span>
                <h3>{project.title}</h3>
              </div>
              <strong>{project.stats[0]}</strong>
            </div>
            <p>{project.description}</p>
          </a>
        </article>
      ))}
    </div>
    <div class="section-footer-row">
      <p class="type-index">Selected examples of recent Evolux project work</p>
      <a href="/projects">Web design projects <span aria-hidden="true">&#8599;</span></a>
    </div>
  </section>

  <section class="studio-intro" id="about">
    <div class="studio-intro__inner">
      <aside class="founder-card founder-card--video" data-video-card>
        <div class="founder-card__video" aria-label="Evolux Web Design video">
          <img
            class="founder-card__poster"
            src="/assets/video/evolux-explainer-poster.jpg"
            alt="Joe from Evolux Web Design explaining the website design process"
            loading="lazy"
            decoding="async"
          />
          <iframe
            src="about:blank"
            data-video-src="https://www.youtube-nocookie.com/embed/dWjJn7rQjNQ?rel=0&modestbranding=1&playsinline=1&autoplay=1"
            title="Evolux Web Design - How we build websites that generate enquiries"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        </div>
        <button class="founder-card__play" type="button" data-video-play aria-label="Play Evolux video">
          <span></span>
          <strong>Watch Joe explain the process</strong>
        </button>
      </aside>

      <div class="studio-intro__content">
        <div class="section-kicker"><span></span><p class="type-index">About Evolux</p></div>
        <h2 class="display-heading">Hey, I'm Joe.<br /><span>Founder of Evolux.</span></h2>
        <div class="copy-stack">
          <p>With 5+ years in web design and development, I founded Evolux in 2023 with a simple idea: businesses across the UK deserve websites that actually generate enquiries - not just look the part.</p>
          <p>I combine technical expertise, brand thinking, and a genuine obsession with conversion to build websites that deliver measurable results. You'll always deal directly with me - no account managers, no handoffs.</p>
        </div>
        <div class="differentiator-list">
          <article><span><Icon name="direct" /></span><div><h3>Direct access</h3><p>You work with me, not an account manager.</p></div></article>
          <article><span><Icon name="target" /></span><div><h3>Conversion focus</h3><p>Every design decision is tied to a business outcome.</p></div></article>
          <article><span><Icon name="launch" /></span><div><h3>Fast delivery</h3><p>From brief to live site in 4-6 weeks, consistently.</p></div></article>
        </div>
        <blockquote class="studio-intro__testimonial">
          <span>"</span>
          <p>Joe's proactive approach and efficient communication made the entire process seamless and stress-free. He brought my business vision to life in ways that exceeded my expectations.</p>
          <footer>Olivia Bowman - Skyn & Glo</footer>
        </blockquote>
        <a class="button button--dark" href="/free-review">Get a free website review <span aria-hidden="true">&#8599;</span></a>
        <a class="text-button" href="/industries">Explore industry website guides <span aria-hidden="true">&#8599;</span></a>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const card = document.querySelector("[data-video-card]");
      if (!card) return;

      const button = card.querySelector("[data-video-play]");
      const iframe = card.querySelector("iframe[data-video-src]");
      if (!button || !iframe) return;

      button.addEventListener("click", () => {
        iframe.src = iframe.dataset.videoSrc;
        card.classList.add("founder-card--playing");
      });
    })();
  </script>

  <section class="credibility-section">
    <div class="section-split">
      <div>
        <div class="section-kicker"><span></span><p class="type-index">The four credibility gaps</p></div>
        <h2 class="display-heading">Sound familiar?</h2>
      </div>
      <p>Most professional services websites fail for the same reason: they look credible enough at first glance, but don't build the trust a potential client needs to actually make contact.</p>
    </div>
    <div class="gap-grid">
      {credibilityGaps.map(({ num, problem, benefit }, index) => (
        <article class:list={["gap-card", index === 0 && "gap-card--lead"]}>
          <div><span>{num}</span><span>&#8599;</span></div>
          <h3>"{problem}"</h3>
          <p class="type-index">What you gain</p>
          <p>{benefit}</p>
        </article>
      ))}
    </div>
    <div class="review-bar">
      <div>
        <h3>Get a clearer read on your own credibility gaps.</h3>
        <p>A free website review will identify the trust, clarity and conversion issues most likely to be affecting enquiries.</p>
      </div>
      <a class="button button--accent" href="/free-review">Get a free website review <span aria-hidden="true">&#8599;</span></a>
    </div>
  </section>

  <section class="process-section" id="process">
    <div class="process-section__head">
      <div>
        <div class="mini-label"><span></span>How it works</div>
        <h2 class="display-heading"><span>Four clear steps.</span><br />You're in control throughout.</h2>
      </div>
      <blockquote>
        <p>"Joe's patience, communication, attention to detail and flare for design combine perfectly to create the ideal online presence."</p>
        <footer>Vicky Jones - McClelland's Bathroom and Tile Studio</footer>
      </blockquote>
    </div>
    <div class="timeline">
      {[
        ["01", "Discovery", "Day 1", "You leave with complete clarity - a sitemap, a content plan, and a clear picture of what your site needs to do for your business."],
        ["02", "Design", "Week 2", "You see the finished user experience and interface in prototype form before a single line of code is written."],
        ["03", "Development", "Weeks 3-5", "You get a fast-loading, fully responsive website built around the approved strategy and design."],
        ["04", "Deployment", "Week 6", "You go live with confidence. Final testing, launch, and a full handover."]
      ].map(([num, title, time, desc]) => (
        <article class="timeline__item">
          <span class="timeline__ghost">{num}</span>
          <div class="timeline__dot"></div>
          <div><h3>{title}</h3><p class="type-index">{time}</p></div>
          <p>{desc}</p>
        </article>
      ))}
    </div>
    <div class="kpi-bar">
      <div><strong>4-6 wks</strong><span class="type-index">From brief to launch</span></div>
      <div><strong>30 days</strong><span class="type-index">Post-launch support</span></div>
      <a class="button button--accent" href="/contact">Contact Evolux <span aria-hidden="true">&#8599;</span></a>
    </div>
  </section>

  <section class="lead-section" id="review">
    <svg class="lead-section__rings lead-section__rings--top" viewBox="0 0 300 300" aria-hidden="true">
      <circle cx="150" cy="150" r="80"></circle>
      <circle cx="150" cy="150" r="120"></circle>
      <circle cx="150" cy="150" r="160"></circle>
    </svg>
    <svg class="lead-section__rings lead-section__rings--bottom" viewBox="0 0 300 300" aria-hidden="true">
      <circle cx="150" cy="150" r="80"></circle>
      <circle cx="150" cy="150" r="120"></circle>
      <circle cx="150" cy="150" r="160"></circle>
    </svg>

    <div class="lead-section__inner">
      <div class="lead-section__copy">
        <div class="mini-label"><span></span>Free website review</div>
        <h2 class="display-heading">See the trust gaps <span>your visitors are reacting to.</span></h2>
        <p>Joe will review your website personally and send a clear video breakdown of the issues most likely to weaken confidence, clarity and enquiry quality.</p>
        <ul>
          <li><strong>20-point review</strong><span>Trust, clarity, mobile experience and conversion friction.</span></li>
          <li><strong>Personal video</strong><span>A practical walkthrough in your inbox within 48 hours.</span></li>
          <li><strong>Clear priorities</strong><span>The changes worth making first, without a sales pitch.</span></li>
        </ul>
        <div class="lead-section__proof">
          <div>
            <strong>5.0</strong>
            <span><b aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</b> Google rating</span>
          </div>
          <div>
            <strong>48h</strong>
            <span>Typical delivery</span>
          </div>
          <a href="/free-review">Review details <span aria-hidden="true">&#8599;</span></a>
        </div>
        <blockquote class="lead-section__testimonial">
          <img src="/assets/logos/steven-dunn-circular-branding.jpg" alt="Steven Dunn, Circular Branding Group" loading="lazy" />
          <div>
            <p>"Clear communication throughout, proactive, responsive and their attention to detail was second to none."</p>
            <footer><strong>Steven Dunn</strong><span>Circular Branding Group</span></footer>
          </div>
        </blockquote>
      </div>

      <form class="lead-form-card" action="/free-review">
        <header class="lead-form-card__head">
          <p class="type-index">Request your free review</p>
          <h3>Show me where the website is losing confidence.</h3>
          <span>Share your details below. It takes around 30 seconds.</span>
        </header>
        <label>
          <span>Your website URL</span>
          <input type="url" name="website" placeholder="https://yourwebsite.co.uk" required />
        </label>
        <label>
          <span>Business email</span>
          <input type="email" name="email" placeholder="you@company.co.uk" required />
        </label>
        <label>
          <span>Biggest website challenge? <em>(optional)</em></span>
          <textarea name="challenge" rows="3" placeholder="For example: traffic but not enough enquiries"></textarea>
        </label>
        <button class="button button--accent" type="submit">Get my free review <span aria-hidden="true">&#8599;</span></button>
        <p>No obligation. No pressure call. Just an honest review from Joe.</p>
      </form>
    </div>
  </section>

  <section class="review-faq home-faq">
    <div class="review-faq__inner">
      <div class="faq-support-card">
        <div class="section-kicker"><span></span><p class="type-index">FAQs</p></div>
        <h2>Before we talk.</h2>
        <div class="faq-support-card__person">
          <img src={JOE_AUTHOR.image} alt="Joe, founder of Evolux Web Design" loading="lazy" />
          <div>
            <strong>Prefer a straight answer?</strong>
            <span>Ask Joe directly.</span>
          </div>
        </div>
        <a class="button button--dark" href="/contact">Ask Joe a question</a>
      </div>
      <div class="faq-accordion-list">
        {homepageFaqs.map(([q, a]) => <details><summary>{q}</summary><p set:html={a}></p></details>)}
      </div>
    </div>
  </section>

  <section class="pricing-section" id="pricing">
    <div class="section-split">
      <div>
        <div class="mini-label"><span></span>Packages</div>
        <h2 class="display-heading"><span>Transparent pricing.</span><br />No surprises.</h2>
      </div>
      <p>Every project is fully scoped before we start. What we quote is what you pay - no extras, no surprises halfway through.</p>
    </div>
    <div class="package-grid">
      {packages.map((pkg) => (
        <PackageCard {...pkg} />
      ))}
    </div>

    <div class="guarantee-bar">
      <div class="guarantee-bar__icon"><Icon name="shield" /></div>
      <div>
        <h3>30-day post-launch guarantee, on every package.</h3>
        <p>If something isn't right in the 30 days after you go live, we fix it. No quibble, no extra charge.</p>
      </div>
      <a href="/free-review">Review my website first <span aria-hidden="true">&#8599;</span></a>
    </div>

    <div class="trust-grid">
      <article><span><Icon name="document" /></span><h3>No hidden costs</h3><p>Fully scoped before we start. What we quote is what you pay.</p></article>
      <article><span><Icon name="direct" /></span><h3>You deal with the designer</h3><p>No account managers. The person building your site is the person you talk to.</p></article>
      <article><span><Icon name="shield" /></span><h3>30-day guarantee</h3><p>Not happy with something in the first 30 days after launch? We fix it.</p></article>
    </div>
  </section>

  <InsightsPreview
    intro="We write about the decisions that grow businesses - not the tools we use to get there."
    footerText="New articles published monthly"
  />
</BaseLayout>
