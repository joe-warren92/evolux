---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Website Review Requested | Evolux"
  description="Thanks for requesting a free Evolux website review."
  robots="noindex, nofollow"
>
  <section class="standard-hero">
    <div class="standard-hero__glow"></div>
    <div class="standard-hero__rule"></div>
    <div class="standard-hero__inner">
      <div class="standard-hero__single">
        <div class="mini-label"><span></span>Request received</div>
        <h1><span>Thanks.</span> Joe will take a look.</h1>
        <p>Your website details are safely through. Joe will review the site personally and send your video within 48 business hours.</p>
        <a class="button button--accent" href="/">Back to the homepage</a>
      </div>
    </div>
  </section>
</BaseLayout>
