---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import InsightsPreview from "../../components/InsightsPreview.astro";
import PackageCard from "../../components/PackageCard.astro";
import { LOCATION_PAGES, type LocationPage } from "../../data/locations";
import { PROJECTS } from "../../data/projects";
import { createFaqSchema } from "../../utils/schema";

export function getStaticPaths() {
  return LOCATION_PAGES.map((location) => ({
    params: { slug: location.slug },
    props: { location }
  }));
}

interface Props {
  location: LocationPage;
}

const { location } = Astro.props;
const { city } = location;
const isNationwide = location.slug === "nationwide";
const heroLocation = isNationwide ? "across the UK" : `in ${city}`;
const packageLabel = isNationwide ? "UK-wide packages" : `${city} packages`;
const industryLabel = "Relevant sectors";
const marketKicker = isNationwide ? "UK-wide website strategy" : "Local website strategy";
const searchKicker = isNationwide ? "UK-wide search intent" : "Local search intent";
const faqHeading = isNationwide ? "Working across the UK." : `Working with ${city}.`;
const ctaHeading = isNationwide
  ? "Make your website easier for serious clients to trust."
  : `Make your ${city} website easier for serious clients to trust.`;
const websiteLabel = isNationwide ? "website" : `${city} website`;
const clientLabel = isNationwide ? "UK clients" : `${city} clients`;
const businessLabel = isNationwide ? "UK businesses" : `${city} businesses`;
const industries = ["Professional services", "Trades & construction", "Healthcare & wellness", "Financial & legal", "Hospitality & leisure", "Retail & e-commerce", "Consultancy", "Recruitment"];
const deliverables = [
  ["Custom design", `Every layout is built for your business. Your ${websiteLabel} should feel specific to your positioning, not adapted from a template.`],
  ["Mobile-first", "The majority of local visitors arrive on a phone. We build mobile-first from day one."],
  ["Conversion architecture", "Structured to guide visitors toward making contact."],
  ["Local SEO", "On-page SEO, schema markup, and Google Business alignment."],
  ["Performance", "Fast-loading pages rank better and convert better."],
  ["Analytics", "GA4 configured with conversion goals."]
];
const deliverableIcons = ["design", "mobile", "target", "seo", "speed", "analytics"];
const selectedCaseStudies = location.caseStudySlugs
  .map((slug) => PROJECTS.find((project) => project.slug === slug))
  .filter(Boolean);
const locationImages: Record<string, { hero: string; local: string; supporting: string; alt: string }> = {
  sunderland: {
    hero: "/assets/locations/sunderland-2.webp",
    local: "/assets/locations/sunderland-1.webp",
    supporting: "/assets/locations/sunderland-3.webp",
    alt: "Sunderland coastline and local landmarks"
  },
  "newcastle-upon-tyne": {
    hero: "/assets/locations/newcastle-2.webp",
    local: "/assets/locations/newcastle-1.webp",
    supporting: "/assets/locations/gateshead-1.webp",
    alt: "Newcastle Quayside and Tyne bridges"
  },
  durham: {
    hero: "/assets/locations/durham-3.webp",
    local: "/assets/locations/durham-1.webp",
    supporting: "/assets/locations/durham-2.webp",
    alt: "Durham Cathedral and riverside cityscape"
  },
  gateshead: {
    hero: "/assets/locations/gateshead-3.webp",
    local: "/assets/locations/gateshead-2.webp",
    supporting: "/assets/locations/gateshead-4.webp",
    alt: "Gateshead Millennium Bridge and Quayside"
  },
  middlesbrough: {
    hero: "/assets/locations/middlesbrough-1.webp",
    local: "/assets/locations/middlesbrough-2.webp",
    supporting: "/assets/locations/gateshead-2.webp",
    alt: "Middlesbrough civic architecture and local business district"
  },
  nationwide: {
    hero: "/assets/locations/newcastle-2.webp",
    local: "/assets/locations/durham-2.webp",
    supporting: "/assets/locations/sunderland-2.webp",
    alt: "North East landmarks representing UK-wide website projects"
  }
};
const locationImage = locationImages[location.slug] ?? locationImages.sunderland;
const packages = [
  ["Launch", "£1,800", "Starting from", `A credible, conversion-ready website to get you in front of ${clientLabel}.`, ["5-page custom design & build", "Mobile-first, fully responsive", "Local SEO foundations", "CMS - edit copy yourself", "Google Business alignment", "14-day post-launch support"]],
  ["Studio", "£3,500", "Starting from", `The full package for ${businessLabel} ready to strengthen their position online.`, ["Up to 12 custom pages", "Full visual identity system", "Conversion-optimised layouts", "Advanced local & on-page SEO", "Analytics & goal tracking", "30-day post-launch support"], true],
  ["Elite", "£6,500", "Starting from", `For ${businessLabel} that want to stand apart and stay there.`, ["Up to 25 custom pages", "Complete brand identity system", "Custom animations", "Conversion-led copywriting", "Advanced local SEO & analytics", "90-day post-launch support"]]
];
const faqSchema = createFaqSchema(
  `https://evoluxwebdesign.co.uk/locations/${location.slug}/#faq`,
  location.faqs
);
---

<BaseLayout
  title={`Web Design ${city} - Evolux Web Design & Development`}
  description={location.seoDescription}
  canonicalPath={`/locations/${location.slug}`}
  structuredData={faqSchema}
  bodyClass="has-image-hero"
>
  <section class="standard-hero location-hero">
    <img class="location-hero__image" src={locationImage.hero} alt="" loading="eager" decoding="async" aria-hidden="true" />
    <div class="standard-hero__glow"></div>
    <div class="standard-hero__rule"></div>
    <div class="standard-hero__inner">
      <div class="location-hero__content">
        <div class="blog-stamp">
          <div class="blog-stamp__crumbs"><a href="/" class="blog-stamp__home"><span>E</span><strong>Evolux</strong></a><span>/</span><a href="/locations">Locations</a><span>/</span><strong>{city}</strong></div>
          <div class="standard-pill">{location.locationLine}</div>
        </div>
        <div class="standard-hero__single">
          <h1><span>Web Design & Development</span> {heroLocation}.</h1>
          <p>{location.heroDescription}</p>
          <div class="service-page-hero__actions"><a class="button button--dark" href="#packages"><span></span>{packageLabel}</a><a class="text-button" href="/free-review">Free website review <span aria-hidden="true">&#8599;</span></a></div>
        </div>
        <div class="service-proof-strip"><span class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span><p class="type-index">5.0 on Google</p><i></i><p class="type-index">{location.locationLine}</p><i></i><p class="type-index">Est. 2023</p><i></i><p class="type-index">30-day post-launch guarantee</p></div>
      </div>
    </div>
  </section>

  <section class="sunderland-local">
    <div class="sunderland-local__inner">
      <div>
        <div class="section-kicker"><span></span><p class="type-index">A local studio</p></div>
        <h2><span>{location.localHeading.split(" ").slice(0, -1).join(" ")}</span><br />{location.localHeading.split(" ").slice(-1)}</h2>
        {location.localParagraphs.map((paragraph) => <p>{paragraph}</p>)}
        <figure class="location-image-placeholder">
          <div>
            <img src={locationImage.local} alt={locationImage.alt} loading="lazy" />
          </div>
          <figcaption>
            <span class="type-index">Location context</span>
            <strong>{isNationwide ? "Built for businesses beyond one postcode" : `Designed around how ${city} clients compare local businesses`}</strong>
            <p>{isNationwide ? "The same strategy-led process works for teams across the UK: clear positioning, stronger proof and a website that makes enquiry feel easy." : `Local pages should feel specific without becoming thin SEO pages. This section connects the place, the audience and the decision-making journey.`}</p>
          </figcaption>
        </figure>
      </div>
      <aside>
        <p class="type-label">{industryLabel}</p>
        <div>{industries.map((industry) => <span><i></i>{industry}</span>)}</div>
        <blockquote><div class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p>"{location.testimonial.quote}"</p><footer><strong>{location.testimonial.name}</strong><em>{location.testimonial.company}</em></footer></blockquote>
      </aside>
    </div>
  </section>

  <section class="location-market">
    <div class="location-market__inner">
      <div class="location-market__intro">
        <div class="section-kicker"><span></span><p class="type-index">{marketKicker}</p></div>
        <h2><span>{location.marketHeading.split(" ").slice(0, -2).join(" ")}</span><br />{location.marketHeading.split(" ").slice(-2).join(" ")}</h2>
        <p>{location.marketIntro}</p>
        <div class="location-market__areas">
          <p class="type-label">Areas covered</p>
          <div>{location.areas.map((area) => <span>{area}</span>)}</div>
        </div>
      </div>
      <div class="location-market__priorities">
        {location.priorities.map((priority, index) => (
          <article>
            <div><span class="type-index">{String(index + 1).padStart(2, "0")}</span><i><Icon name={priority.icon} /></i></div>
            <h3>{priority.title}</h3>
            <p>{priority.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="location-seo-depth">
    <div class="location-seo-depth__inner">
      <div class="location-seo-depth__intro">
        <div class="section-kicker"><span></span><p class="type-index">{searchKicker}</p></div>
        <h2><span>{location.localSeoSection.heading.split(" ").slice(0, -3).join(" ")}</span><br />{location.localSeoSection.heading.split(" ").slice(-3).join(" ")}</h2>
        <p>{location.localSeoSection.intro}</p>
        <figure class="location-image-placeholder location-image-placeholder--compact">
          <div>
            <img src={locationImage.supporting} alt={`${locationImage.alt} supporting visual`} loading="lazy" />
          </div>
          <figcaption>
            <span class="type-index">Search context</span>
            <strong>{isNationwide ? "Trust signals still matter when distance is irrelevant" : `Search visibility has to support the way ${city} customers decide`}</strong>
            <p>{isNationwide ? "For UK-wide projects, the website has to make the process, proof and next step feel clear before a call is booked." : `The content should answer practical questions, show genuine relevance and give visitors a confident next step.`}</p>
          </figcaption>
        </figure>
      </div>
      <div class="location-seo-depth__content">
        <div class="location-seo-depth__points">
          {location.localSeoSection.points.map((point, index) => (
            <article>
              <span class="type-index">{String(index + 1).padStart(2, "0")}</span>
              <h3>{point.title}</h3>
              <p>{point.description}</p>
            </article>
          ))}
        </div>
        <aside>
          <p class="type-index">SEO priority</p>
          <strong>{location.localSeoSection.note}</strong>
          <a href="/free-review">Review your current website <span aria-hidden="true">&#8599;</span></a>
        </aside>
      </div>
    </div>
  </section>

  <section class="service-deliverables">
    <div class="service-deliverables__inner">
      <div class="section-heading-row">
        <div><div class="section-kicker"><span></span><p class="type-index">What's included</p></div><h2><span>Everything your</span><br />website needs.</h2></div>
        <p>{location.marketDescription}</p>
      </div>
      <div class="service-deliverables__grid">{deliverables.map(([title, desc], index) => <article><div><Icon name={deliverableIcons[index] ?? "star"} /></div><h3>{title}</h3><p>{desc}</p></article>)}</div>
    </div>
  </section>

  <section class="service-case-studies location-case-studies">
    <div class="service-case-studies__inner">
      <div class="section-heading-row">
        <div>
          <div class="section-kicker"><span></span><p class="type-index">Selected work</p></div>
          <h2><span>Credibility built</span><br />into the work.</h2>
        </div>
        <p>Different sectors, different audiences, and the same focus on making the business easier to trust and easier to choose.</p>
      </div>
      <div class="service-case-studies__grid">
        {selectedCaseStudies.map((project, index) => project && (
          <a class:list={["service-case-card", index === 0 && "service-case-card--featured"]} href={`/projects/${project.slug}`}>
            <figure>
              <img src={project.hero} alt={`${project.title} website project`} loading="lazy" />
              <span class="type-index">{String(index + 1).padStart(2, "0")}</span>
            </figure>
            <div class="service-case-card__body">
              <div>
                <p class="type-index">{project.industry}</p>
                <h3>{project.title}</h3>
              </div>
              <span class="service-case-card__arrow" aria-hidden="true"><Icon name="arrow" /></span>
              <p>{project.description}</p>
              <strong>Read the case study</strong>
            </div>
          </a>
        ))}
      </div>
      <div class="service-case-studies__footer">
        <p>Looking for more examples across different sectors?</p>
        <a href="/projects">Explore web design projects <span aria-hidden="true">&#8599;</span></a>
      </div>
    </div>
  </section>

  <section class="service-packages" id="packages">
    <div class="service-packages__inner">
      <div class="section-heading-row"><div><div class="section-kicker"><span></span><p class="type-index">Packages</p></div><h2><span>Transparent pricing.</span><br />No surprises.</h2></div><p>Fully scoped before we start. What we quote is what you pay.</p></div>
      <div class="service-package-grid">
        {packages.map(([name, price, note, tagline, features, highlight]) => (
          <PackageCard
            id={String(name).toLowerCase().replaceAll(" ", "-")}
            name={String(name)}
            price={String(price)}
            note={String(note)}
            tagline={String(tagline)}
            features={features as string[]}
            highlight={Boolean(highlight)}
            ctaHref="/free-review"
            ctaText={`${name} website review`}
          />
        ))}
      </div>
    </div>
  </section>

  <InsightsPreview
    slugs={isNationwide
      ? ["why-websites-dont-generate-business", "questions-to-ask-web-design-agency", "understanding-website-costs-in-2025"]
      : ["how-a-sunderland-web-design-agency-helps-small-businesses-grow", "how-sunderland-businesses-can-stand-out-online-smarter-website-design", "finding-web-design-north-east"]}
    headingMuted="Useful reading for"
    heading={isNationwide ? "UK website projects." : `${city} businesses.`}
    intro={isNationwide
      ? "Practical guides for businesses comparing website investment, trust signals and what to improve before a rebuild."
      : `Advice on local visibility, website credibility and how ${city} businesses can make the right first impression online.`}
    footerText={isNationwide ? "Website planning articles" : `${city} web design articles`}
  />

  <section class="review-faq">
    <div class="review-faq__inner">
      <div class="faq-support-card">
        <p class="type-index">FAQs</p>
        <h2>{faqHeading}</h2>
        <div class="faq-support-card__person">
          <img src="/assets/logos/joe-evolux-founder.png" alt="Joe, founder of Evolux Web Design" loading="lazy" />
          <div><strong>Planning a local project?</strong><span>Ask Joe directly.</span></div>
        </div>
        <a class="button button--dark" href="/contact">Talk to Joe</a>
      </div>
      <div class="faq-accordion-list">
        {location.faqs.map(([q, a]) => <details><summary>{q}</summary><p set:html={a}></p></details>)}
      </div>
    </div>
  </section>

  <section class="service-dark-cta">
    <div>
      <p class="type-index">Free website review</p>
      <h2>{ctaHeading}</h2>
      <p>Start with a free review of your current website. Joe will assess the clarity, proof and conversion friction, then send a personalised video within 48 hours.</p>
      <div><a class="button button--accent" href="/free-review">Free website review</a><a href="/contact">Contact Joe <span aria-hidden="true">&#8599;</span></a></div>
    </div>
  </section>
</BaseLayout>
