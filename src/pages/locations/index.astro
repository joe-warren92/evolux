---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import InsightsPreview from "../../components/InsightsPreview.astro";
import { LOCATION_PAGES } from "../../data/locations";

const workflowIcons = ["message", "design", "clock", "launch"];
---

<BaseLayout
  title="Web Design Locations | Sunderland, North East & UK | Evolux"
  description="Evolux provides premium, conversion-focused web design in Sunderland, Newcastle, Durham, Gateshead, Middlesbrough and across the UK."
>
  <section class="standard-hero">
    <div class="standard-hero__glow"></div>
    <div class="standard-hero__rule"></div>
    <div class="standard-hero__inner">
      <div class="blog-stamp"><div class="blog-stamp__crumbs"><a href="/" class="blog-stamp__home"><span>E</span><strong>Evolux</strong></a><span>/</span><strong>Locations</strong></div></div>
      <div class="standard-hero__single">
        <h1><span>Based in Sunderland.</span> Working across the UK.</h1>
        <p>Evolux was founded in Sunderland in 2023 and has grown to serve businesses across the North East and beyond. Every client gets the same level of attention whether they're in Sunderland or Southampton.</p>
      </div>
    </div>
  </section>

  <section class="locations-grid-section">
    <div class="locations-grid-section__inner">
      <div class="section-kicker"><span></span><p class="type-index">Areas we serve</p></div>
      <div class="locations-grid">
        {LOCATION_PAGES.map((location) => (
          <article class:list={["location-card", location.slug === "sunderland" && "location-card--active"]}>
            <a href={`/locations/${location.slug}`}>
              <div><span>{location.archiveLabel}</span><em>&#8599;</em></div>
              <h2>{location.city}</h2>
              <p class="type-index">{location.region}</p>
              <p>{location.archiveDescription}</p>
              <strong>View {location.city} web design services <span aria-hidden="true">&#8599;</span></strong>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="location-workflow">
    <div class="location-workflow__inner">
      <div>
        <div class="section-kicker"><span></span><p class="type-index">How we work</p></div>
        <h2><span>Location doesn't</span><br />limit great work.</h2>
        <p>All discovery, design review, and handover sessions are run via video call. We've delivered projects for clients we've never met in person, and the results speak for themselves.</p>
      </div>
      <div>
        {[
          ["Discovery call", "Your first session is a 45-minute strategy call via Zoom or Google Meet."],
          ["Design review", "Figma prototypes are shared via link so you can comment directly."],
          ["Regular check-ins", "You'll get weekly progress updates and can reach Joe directly."],
          ["Launch & handover", "Full CMS training via screenshare."]
        ].map(([heading, body], index) => <article><span><Icon name={workflowIcons[index] ?? "star"} /></span><h3>{heading}</h3><p>{body}</p></article>)}
      </div>
    </div>
  </section>

  <InsightsPreview
    slugs={["how-a-sunderland-web-design-agency-helps-small-businesses-grow", "finding-web-design-north-east", "web-designer-near-me-2"]}
    headingMuted="Local website advice"
    heading="for North East businesses."
    intro="Guides covering local search, choosing a web designer and building a website that supports both Google visibility and real enquiries."
    footerText="Local web design articles"
  />

  <section class="review-bottom-cta">
    <div>
      <h2><span>Need a website that feels local</span><br />without thinking small?</h2>
      <p>Start with a free review and Joe will show where your current site could build more trust with the people you want to hear from.</p>
      <a class="button button--dark" href="/free-review"><span></span>Free website review</a>
    </div>
  </section>
</BaseLayout>
