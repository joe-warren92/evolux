---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";

const industries = ["Professional services", "Trades & construction", "Healthcare & wellness", "Financial & legal", "Hospitality & leisure", "Retail & e-commerce", "Consultancy", "Recruitment"];
const deliverables = [
  ["Custom design", "Every layout is built for your business. No Sunderland business looks like any other, and neither should your website."],
  ["Mobile-first", "The majority of your local visitors arrive on a phone. We build mobile-first from day one."],
  ["Conversion architecture", "Structured to guide visitors toward making contact."],
  ["Local SEO", "On-page SEO, schema markup, and Google Business alignment."],
  ["Performance", "Fast-loading pages rank better and convert better."],
  ["Analytics", "GA4 configured with conversion goals."]
];

const deliverableIcons = ["design", "mobile", "target", "seo", "speed", "analytics"];
---

<BaseLayout title="Web Design Sunderland - Evolux Web Design & Development">
  <section class="standard-hero">
    <div class="standard-hero__glow"></div>
    <div class="standard-hero__rule"></div>
    <div class="standard-hero__inner">
      <div class="blog-stamp">
        <div class="blog-stamp__crumbs"><a href="/" class="blog-stamp__home"><span>E</span><strong>Evolux</strong></a><span>/</span><a href="/locations">Locations</a><span>/</span><strong>Sunderland</strong></div>
        <div class="standard-pill">Sunderland, Tyne & Wear, SR1</div>
      </div>
      <div class="standard-hero__single">
        <h1><span>Web Design & Development</span><br />in Sunderland.</h1>
        <p>Evolux is a Sunderland-based web design studio. We build conversion-focused websites for local businesses that want to win more enquiries, not just more traffic.</p>
        <div class="service-page-hero__actions"><a class="button button--dark" href="#packages"><span></span>View packages & pricing</a><a class="text-button" href="/free-review">Free website review <span aria-hidden="true">&#8599;</span></a></div>
      </div>
      <div class="service-proof-strip"><span class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span><p class="type-index">5.0 on Google</p><i></i><p class="type-index">Sunderland, Tyne & Wear</p><i></i><p class="type-index">Est. 2023</p><i></i><p class="type-index">30-day post-launch guarantee</p></div>
    </div>
  </section>

  <section class="sunderland-local">
    <div class="sunderland-local__inner">
      <div>
        <div class="section-kicker"><span></span><p class="type-index">A local studio</p></div>
        <h2><span>We know Sunderland</span><br />business.</h2>
        <p>Evolux was founded in Sunderland by Joe in 2023. We've worked with businesses across the city and understand what the Sunderland market looks like from the inside.</p>
        <p>That local knowledge informs every project. We know who your competitors are, how local customers search, and what it takes to stand out in the North East market.</p>
      </div>
      <aside>
        <p class="type-label">Industries we serve in Sunderland</p>
        <div>{industries.map((industry) => <span><i></i>{industry}</span>)}</div>
        <blockquote><div class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p>"We couldn't be happier with the new website Joe created for us. It truly captures who we are."</p><footer><strong>Katie Dutton</strong><em>Manton Executives, Sunderland</em></footer></blockquote>
      </aside>
    </div>
  </section>

  <section class="service-deliverables">
    <div class="service-deliverables__inner">
      <div class="section-heading-row">
        <div><div class="section-kicker"><span></span><p class="type-index">What's included</p></div><h2><span>Everything your</span><br />website needs.</h2></div>
        <p>Every Sunderland project includes the same complete build: design, development, performance, SEO, and analytics.</p>
      </div>
      <div class="service-deliverables__grid">{deliverables.map(([title, desc], index) => <article><div><Icon name={deliverableIcons[index] ?? "star"} /></div><h3>{title}</h3><p>{desc}</p></article>)}</div>
    </div>
  </section>

  <section class="service-packages" id="packages">
    <div class="service-packages__inner">
      <div class="section-heading-row"><div><div class="section-kicker"><span></span><p class="type-index">Packages</p></div><h2><span>Transparent pricing.</span><br />No surprises.</h2></div><p>Fully scoped before we start. What we quote is what you pay.</p></div>
      <div class="service-package-grid">
        {[
          ["Launch", "£1,800", "Starting from", "A credible, conversion-ready website to get you in front of Sunderland clients.", ["5-page custom design & build", "Mobile-first, fully responsive", "Local SEO foundations", "CMS - edit copy yourself", "Google Business alignment", "14-day post-launch support"]],
          ["Studio", "£3,500", "Starting from", "The full package for Sunderland businesses ready to dominate local search.", ["Up to 12 custom pages", "Full visual identity system", "Conversion-optimised layouts", "Advanced local & on-page SEO", "Analytics & goal tracking", "30-day post-launch support"], true],
          ["Elite", "£6,500", "Starting from", "For Sunderland businesses that want to stand apart and stay there.", ["Up to 25 custom pages", "Complete brand identity system", "Custom animations", "Conversion-led copywriting", "Advanced local SEO & analytics", "90-day post-launch support"]]
        ].map(([name, price, note, tagline, features, highlight]) => <article class:list={["service-package-card", highlight && "service-package-card--featured"]}>{highlight && <span class="service-package-card__badge">Most popular</span>}<p class="type-label">{name}</p><h3>{price}</h3><span class="type-index">{note}</span><p>{tagline}</p><ul>{features.map((feature) => <li>{feature}</li>)}</ul><a href="/free-review">Start with {name} <span aria-hidden="true">&#8599;</span></a></article>)}
      </div>
    </div>
  </section>

  <section class="review-faq">
    <div class="review-faq__inner">
      <div class="section-kicker"><span></span><p class="type-index">FAQ</p></div>
      <h2><span>Questions about</span><br />working with us.</h2>
      {[
        ["Are you actually based in Sunderland?", "Yes. Evolux was founded in Sunderland, Tyne & Wear, and works with businesses across the city, the wider North East and the rest of the UK. That local base helps when planning web design, local SEO, Google Business visibility and messaging for Sunderland customers."],
        ["Do you meet Sunderland clients in person?", "In-person meetings can be arranged for Sunderland and nearby North East clients where useful, especially for discovery or photography planning. Most strategy, design review and handover sessions are handled by video call because it keeps projects moving quickly and gives clients a clear record of decisions."],
        ["Can you help with local SEO for Sunderland businesses?", "Yes. Local SEO is built into every Sunderland web design project. That includes search-friendly page structure, service/location relevance, metadata, heading hierarchy, performance, schema considerations and Google Business alignment. For more competitive local searches, Evolux can also recommend ongoing SEO content and landing page opportunities."],
        ["Do you work with small local businesses?", "Absolutely. Evolux works well with owner-managed and growing Sunderland businesses that need a website to build trust, explain their offer clearly and generate more enquiries. The project can be scoped around the stage your business is at, from a focused Launch website to a deeper Studio or Elite build."],
        ["What types of Sunderland businesses do you work with?", "Evolux works with professional services, trades, construction, healthcare, wellness, legal, finance, consultancy, recruitment, hospitality, leisure and other service-based businesses. The common thread is not the industry, but the need for a premium, conversion-focused website that helps customers choose you with confidence."]
      ].map(([q, a]) => <details><summary>{q}</summary><p>{a}</p></details>)}
    </div>
  </section>

  <section class="service-dark-cta">
    <div>
      <p class="type-index">Sunderland, Tyne & Wear</p>
      <h2>Ready to grow your Sunderland business online?</h2>
      <p>Start with a free review of your current website. Joe will assess it against 20 conversion factors and send you a personalised video in 48 hours.</p>
      <div><a class="button button--accent" href="/free-review">Get a free website review</a><a href="mailto:info@evoluxwebdesign.co.uk">Or email Joe directly <span aria-hidden="true">&#8599;</span></a></div>
    </div>
  </section>
</BaseLayout>
