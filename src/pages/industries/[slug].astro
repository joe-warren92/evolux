---
import IndustryPage from "../../components/IndustryPage.astro";
import { INDUSTRIES } from "../../data/industries";

export function getStaticPaths() {
  return INDUSTRIES.map((industry) => ({ params: { slug: industry.slug }, props: { industry } }));
}

const { industry } = Astro.props;
---

<IndustryPage industry={industry} />
