---
import "../styles/main.css";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  includeFounderSchema?: boolean;
  includePersonSchema?: boolean;
}

const {
  title = "Evolux Web Design | Websites That Generate Enquiries",
  description = "A premium web design studio building conversion-focused websites for ambitious UK businesses.",
  structuredData = [],
  includeFounderSchema = false,
  includePersonSchema = false
} = Astro.props;

const siteUrl = "https://evoluxwebdesign.co.uk";
const localBusinessId = `${siteUrl}/#localbusiness`;
const personId = `${siteUrl}/#joe`;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": localBusinessId,
  name: "Evolux Web Design",
  url: siteUrl,
  telephone: "+447854932203",
  email: "info@evoluxwebdesign.co.uk",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Sunderland",
    addressRegion: "Tyne and Wear",
    addressCountry: "GB"
  },
  openingHours: "Mo-Fr 09:00-17:00",
  ...(includeFounderSchema && { founder: { "@id": personId } })
};

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": personId,
  name: "Joe",
  jobTitle: "Founder",
  worksFor: { "@id": localBusinessId }
};

const pageStructuredData = Array.isArray(structuredData) ? structuredData : [structuredData];
const jsonLdSchemas = [
  localBusinessSchema,
  ...(includePersonSchema || includeFounderSchema ? [personSchema] : []),
  ...pageStructuredData
].filter((schema) => Object.keys(schema).length > 0);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" href="/favicon.svg" />
    <title>{title}</title>
    {jsonLdSchemas.map((schema) => <script type="application/ld+json" set:html={JSON.stringify(schema)} />)}
  </head>
  <body>
    <Navigation />
    <main id="content">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      (() => {
        const header = document.querySelector("[data-site-header]");
        const mobileNav = document.querySelector("[data-mobile-nav]");
        const menu = document.querySelector("[data-mobile-menu]");

        if (!header || !mobileNav || !menu) return;

        const setHeaderState = () => {
          header.classList.toggle("site-header--scrolled", window.scrollY > 16 || mobileNav.open);
        };

        const setMenuOpen = (open) => {
          mobileNav.open = open;
          document.body.classList.toggle("is-menu-open", open);
          setHeaderState();
        };

        setHeaderState();
        window.addEventListener("scroll", setHeaderState, { passive: true });
        mobileNav.addEventListener("toggle", () => {
          setMenuOpen(mobileNav.open);
        });
        menu.addEventListener("click", (event) => {
          if (event.target.closest("a")) setMenuOpen(false);
        });
        window.addEventListener("keydown", (event) => {
          if (event.key === "Escape") setMenuOpen(false);
        });
        window.addEventListener("resize", () => {
          if (window.matchMedia("(min-width: 1025px)").matches) setMenuOpen(false);
        });
      })();
    </script>
  </body>
</html>
